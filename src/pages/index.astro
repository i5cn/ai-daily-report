---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportCard from '../components/ui/ReportCard.astro';
import type { DailyReport, ReportCard as ReportCardType, CommunityItem } from '../types/report';

// ========== 数据读取工具函数 ==========

const EMPTY_DAILY_REPORT: DailyReport = {
  version: '1.0',
  meta: {
    date: new Date().toISOString().split('T')[0],
    edition: 'AI-Daily-Empty',
    generatedAt: new Date().toISOString(),
    totalCount: 0,
    tagStats: {
      model: 0,
      product: 0,
      research: 0,
      industry: 0,
      tool: 0,
      policy: 0,
      event: 0,
      funding: 0,
    },
    editorNote: '暂无今日数据，请稍后刷新或联系管理员。',
  },
  items: [],
  sourceStats: [],
  communityPulse: [],
  communityStats: [],
};

function loadLatestReport(): DailyReport {
  try {
    const latestPath = path.join(process.cwd(), 'data', 'reports', 'latest.json');
    
    if (!fs.existsSync(latestPath)) {
      return EMPTY_DAILY_REPORT;
    }

    const content = fs.readFileSync(latestPath, 'utf-8');
    const data = JSON.parse(content) as DailyReport;

    if (!data || typeof data !== 'object') {
      return EMPTY_DAILY_REPORT;
    }

    if (!Array.isArray(data.items)) {
      data.items = [];
    }

    if (!data.meta) {
      data.meta = EMPTY_DAILY_REPORT.meta;
    }

    return data;
  } catch {
    return EMPTY_DAILY_REPORT;
  }
}

// ========== 加载数据 ==========

const report = loadLatestReport();
const { meta, items, sourceStats, communityPulse, communityStats } = report;

// 确保 communityPulse 和 communityStats 存在
const safeCommunityPulse = communityPulse || [];
const safeCommunityStats = communityStats || [];

// 按 hotScore 排序
const sortedItems = [...items].sort((a, b) => (b.hotScore || 0) - (a.hotScore || 0));

// ========== 数据分组 ==========

// 今日重点：取 hotScore 最高的内容
const heroSignals = sortedItems.slice(0, 8);

// 社区热议按 hotScore 排序，取前 4 条
const sortedCommunity = [...safeCommunityPulse].sort((a, b) => {
  return (b.hotScore || 0) - (a.hotScore || 0);
}).slice(0, 4);

// 是否有数据
const hasData = items.length > 0;
const hasCommunityData = safeCommunityPulse.length > 0;

// 统计数据
const totalCount = meta.totalCount;
const communityCount = meta.communityCount || safeCommunityPulse.length;
const sourceCount = sourceStats?.length || new Set(items.map(i => i.source)).size || 12;

// 格式化日期
const displayDate = new Date(meta.date || Date.now()).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long'
});

const shortDate = new Date(meta.date || Date.now()).toLocaleDateString('zh-CN', {
  month: 'short',
  day: 'numeric'
});

// 标签中文映射
const tagLabels: Record<string, string> = {
  model: '模型',
  product: '产品',
  research: '研究',
  industry: '行业',
  tool: '工具',
  policy: '政策',
};

const tagIcons: Record<string, string> = {
  model: '⚡',
  product: '✦',
  research: '◈',
  industry: '◉',
  tool: '⚙',
  policy: '◆',
};

const signalBrief = meta.editorNote || (hasData
  ? `今日共收录 ${totalCount} 条 AI 资讯，覆盖 ${sourceCount} 个主要信源。`
  : '暂无今日信号，请稍后刷新。');

const sweepCategories = (['model', 'product', 'research', 'industry', 'tool', 'policy'] as const)
  .map((tag) => {
    const categoryItems = sortedItems.filter(item => item.tags?.includes(tag)).slice(0, 4);

    return {
      key: tag,
      label: tagLabels[tag] || tag,
      icon: tagIcons[tag] || '◆',
      count: meta.tagStats?.[tag] || categoryItems.length,
      items: categoryItems,
    };
  })
  .filter(category => category.count > 0 && category.items.length > 0);

const topTagSignals = Object.entries(meta.tagStats || {})
  .filter(([, count]) => count > 0)
  .sort(([, countA], [, countB]) => countB - countA)
  .slice(0, 3)
  .map(([tag, count]) => ({
    tag,
    count,
    label: tagLabels[tag] || tag,
  }));

const generatedTime = new Date(meta.generatedAt || Date.now()).toLocaleTimeString('zh-CN', {
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
});

const topSources = (sourceStats || []).slice(0, 5);
const heroStatusLabels: Record<string, string> = {
  model: 'model signals',
  product: 'product launches',
  research: 'research drops',
  industry: 'industry moves',
  tool: 'tool updates',
  policy: 'policy shifts',
};

const heroStatusSummary = topTagSignals.length > 0
  ? topTagSignals
      .map(({ tag, count }) => `${count} ${heroStatusLabels[tag] || `${tag} signals`}`)
      .join(' / ')
  : `${totalCount} signals / ${sourceCount} sources / updated ${generatedTime}`;

const heroMarqueeItems = heroSignals.length > 0
  ? [...heroSignals, ...heroSignals]
  : [];

const navLinks = [
  heroSignals.length > 0 ? { href: '#top-signals', label: 'Top Signals' } : null,
  hasData ? { href: '#categories', label: 'Categories' } : null,
  hasCommunityData ? { href: '#community', label: 'Community' } : null,
  { href: '#source-ledger', label: 'Ledger' },
].flatMap((link) => (link ? [link] : []));
---

<BaseLayout title="AI Signal Surface - 每日 AI 资讯聚合" description="Personal AI signal surface for scanning models, products, research, and community pulse.">
  <!-- Stage Background -->
  <div class="stage-bg" aria-hidden="true">
    <div class="stage-spotlight"></div>
    <div class="stage-ambient-cool"></div>
    <div class="stage-ambient-purple"></div>
    <div class="stage-depth"></div>
    <div class="stage-particles"></div>
    <div class="stage-texture"></div>
    <div class="stage-grid"></div>
  </div>

  <main id="main-content">
    <div id="page-top" aria-hidden="true"></div>
    <header class="global-rail" aria-label="Global Rail">
      <div class="global-rail-inner">
        <a href="#page-top" class="global-rail-brand">
          <span class="global-rail-brand-mark"></span>
          <span>AI Signal Surface</span>
        </a>
        <div class="global-rail-status">
          <span class="global-rail-date">{shortDate}</span>
          <span class="global-rail-separator">/</span>
          <span>{hasData ? `${totalCount} items` : 'standby'}</span>
        </div>
        <nav class="global-rail-nav" aria-label="Primary">
          {navLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>
    </header>

  <!-- ========== BLOCK 1: SIGNAL DECK - 舞台首屏 ========== -->
  <section class="hero" id="signal-deck" aria-labelledby="signal-deck-title">
    <div class="hero-stage">
      <div class="hero-brand-mark" aria-hidden="true">
        <span class="hero-brand-core"></span>
        <span class="hero-brand-ring hero-brand-ring-red"></span>
        <span class="hero-brand-ring hero-brand-ring-blue"></span>
      </div>

      <div class="hero-copy">
        <p class="hero-kicker">Personal AI Signal Surface</p>
        <h1 class="hero-title" id="signal-deck-title">AI Signal Surface</h1>
        <p class="hero-subtitle">The AI feed that actually matters.</p>
        <p class="hero-lead">
          每日聚合 AI signals，快速扫读模型、产品、研究与 community pulse。
          为自己保留一个更轻、更快、更有判断感的资讯入口。
        </p>
        <a class="hero-status-pill" href={hasData ? '#categories' : '#source-ledger'}>
          <span class="hero-status-badge">NEW</span>
          <span class="hero-status-copy">{heroStatusSummary}</span>
          <span class="hero-status-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      {heroSignals.length > 0 && (
        <section class="hero-marquee-shell" id="top-signals" aria-labelledby="top-signals-title">
          <div class="hero-marquee-header">
            <h2 class="hero-marquee-title" id="top-signals-title">What People Scan</h2>
            <a href="#categories" class="hero-marquee-link">View all →</a>
          </div>
          <div class="signal-marquee">
            <div class="signal-marquee-fade signal-marquee-fade-left" aria-hidden="true"></div>
            <div class="signal-marquee-fade signal-marquee-fade-right" aria-hidden="true"></div>
            <div class="signal-marquee-track" style={`--marquee-count: ${heroSignals.length};`}>
              {heroMarqueeItems.map((item, index) => (
                <a
                  href={item.sourceUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="signal-marquee-card"
                  aria-label={`打开资讯：${item.title}`}
                >
                  <div class="signal-marquee-avatar" aria-hidden="true">
                    {(item.source || 'AI').slice(0, 1).toUpperCase()}
                  </div>
                  <div class="signal-marquee-content">
                    <div class="signal-marquee-meta">
                      <span class="signal-marquee-source">{item.source}</span>
                      <span class="signal-marquee-hot">{item.hotScore || 50}°</span>
                    </div>
                    <h3 class="signal-marquee-card-title">{item.title}</h3>
                    <p class="signal-marquee-summary">
                      {item.summary?.trim() || 'High-signal item from today’s feed.'}
                    </p>
                    <div class="signal-marquee-tags">
                      <span>{(item.tags || []).slice(0, 2).map((tag) => tagLabels[tag] || tag).join(' / ') || 'Signal'}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}
    </div>
    
    <!-- 滚动指示 -->
    <div class="hero-scroll">
      <div class="scroll-hint">
        <span>向下探索</span>
        <div class="scroll-line">
          <div class="scroll-line-progress"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BLOCK 3: CATEGORY SWEEP - 分类节奏 ========== -->
  {hasData && (
    <section class="block block-categories" id="categories" aria-labelledby="category-sweep-title">
      <div class="block-container">
        <header class="block-header block-header-center">
          <span class="header-eyebrow">分类浏览</span>
          <h2 class="header-title" id="category-sweep-title">Category Sweep</h2>
          <p class="header-desc">{displayDate} · 共 {totalCount} 条</p>
          <div class="category-sweep-controls" aria-label="分类筛选">
            <button type="button" class="category-sweep-control is-active" data-category-filter="all" aria-pressed="true">
              全部
            </button>
            {sweepCategories.map((category) => (
              <button
                type="button"
                class="category-sweep-control"
                data-category-filter={category.key}
                aria-pressed="false"
              >
                <span>{category.icon} {category.label}</span>
                <span class="category-sweep-control-count">{category.count}</span>
              </button>
            ))}
          </div>
        </header>
        
        <div class="category-sweep-panels" data-category-sweep-root>
          <div class="category-sweep-panel is-active" data-category-panel="all">
            <div class="categories-content">
              {sweepCategories.map((category) => (
                <div class="category-section">
                  <div class="category-header">
                    <span class="category-icon">{category.icon}</span>
                    <h3 class="category-title">{category.label}</h3>
                    <span class="category-count">{category.count}</span>
                  </div>
                  <div class="category-cards">
                    {category.items.map((item, index) => (
                      <ReportCard 
                        id={item.id}
                        title={item.title}
                        summary={item.summary}
                        source={item.source}
                        sourceUrl={item.sourceUrl}
                        publishedAt={item.publishedAt}
                        imageUrl={item.imageUrl}
                        tags={item.tags}
                        index={index}
                        variant="compact"
                      />
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>

          {sweepCategories.map((category) => (
            <div class="category-sweep-panel category-sweep-panel-single" data-category-panel={category.key} hidden>
              <div class="category-section">
                <div class="category-header">
                  <span class="category-icon">{category.icon}</span>
                  <h3 class="category-title">{category.label}</h3>
                  <span class="category-count">{category.count}</span>
                </div>
                <div class="category-cards">
                  {category.items.map((item, index) => (
                    <ReportCard 
                      id={item.id}
                      title={item.title}
                      summary={item.summary}
                      source={item.source}
                      sourceUrl={item.sourceUrl}
                      publishedAt={item.publishedAt}
                      imageUrl={item.imageUrl}
                      tags={item.tags}
                      index={index}
                      variant="compact"
                    />
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========== BLOCK 4: COMMUNITY PULSE - 社交节奏 ========== -->
  {hasCommunityData && sortedCommunity.length > 0 && (
    <section class="block block-community" id="community" aria-labelledby="community-pulse-title">
      <div class="block-container">
        <header class="block-header block-header-community">
          <div class="header-accent header-accent-community"></div>
          <div class="header-content">
            <span class="header-eyebrow">Reddit</span>
            <h2 class="header-title" id="community-pulse-title">Community Pulse</h2>
          </div>
          <p class="header-desc">来自 AI 社区的热门讨论</p>
        </header>
        
        <div class="community-pulse-band">
          <div class="community-grid">
            {sortedCommunity.map((item, index) => (
              <article class="community-card" style={`--delay: ${index * 100}ms`}>
                <div class="community-card-inner">
                  <div class="community-meta">
                    <span class="community-subreddit">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 3.48 2.737 0 2.384-2.153 2.625-2.178 2.641l-.003.002c-.418.191-.706.159-1.122.241v.001c-.476.094-.798.137-1.179.137-.644 0-1.236-.093-1.754-.286-.647-.238-1.186-.59-1.592-1.035-.406-.445-.7-.978-.873-1.592a4.27 4.27 0 0 1-.077-1.887c.124-.511.355-.974.686-1.374.331-.4.753-.718 1.256-.949.503-.231 1.075-.347 1.703-.347.29 0 .574.02.848.061.273.04.544.104.81.188l.462-2.164h.002l.393-1.846c.032-.155.16-.27.319-.27h.002l2.53.533zm-5.077 5.827c-.521 0-.949.115-1.274.345-.325.23-.56.55-.695.956a2.49 2.49 0 0 0 .049 1.216c.125.41.349.752.668 1.019.319.267.72.401 1.195.401.277 0 .535-.04.772-.117.237-.078.46-.202.668-.37v-.001l.003-.002c.234-.19.408-.437.522-.737a2.22 2.22 0 0 0 .054-1.06 1.962 1.962 0 0 0-.597-.96 1.661 1.661 0 0 0-1.149-.425c-.166 0-.324.015-.472.044l-.016.003a1.94 1.94 0 0 0-.332.076l-.007.002h-.002c-.029.008-.057.018-.084.029l-.008.003zm8.58 1.17a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75zm-10.01 0a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75z"/>
                      </svg>
                      r/{item.subreddit}
                    </span>
                    <span class="community-hot">{item.hotScore}°</span>
                  </div>
                  <h3 class="community-title">
                    <a href={item.discussionUrl || item.sourceUrl} target="_blank" rel="noopener noreferrer">
                      {item.title}
                    </a>
                  </h3>
                  <p class="community-summary">{item.summary}</p>
                  <a href={item.discussionUrl || item.sourceUrl} target="_blank" rel="noopener noreferrer" class="community-link">
                    查看讨论
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                      <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
        
        <div class="community-footer">
          <a href="https://www.reddit.com/r/artificial/" target="_blank" rel="noopener noreferrer" class="community-more">
            更多 Reddit 讨论
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ========== BLOCK 5: SOURCE LEDGER - 行动召唤 ========== -->
  <section class="block block-continue" id="source-ledger" aria-labelledby="source-ledger-title">
    <div class="block-container">
      <div class="source-ledger-grid">
        <div class="source-ledger-note">
          <div class="continue-orb" aria-hidden="true"></div>
          <span class="source-ledger-kicker">Source Ledger</span>
          <h2 class="continue-title" id="source-ledger-title">今日信号覆盖</h2>
          <p class="continue-desc">{signalBrief}</p>
          <div class="source-ledger-stats">
            <span>Items {totalCount}</span>
            <span>Sources {sourceCount}</span>
            <span>Community {communityCount}</span>
          </div>
          <div class="continue-actions">
            <a href="#page-top" class="continue-btn continue-btn-primary">
              回到顶部
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M8 12V4M4 8l4-4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#categories" class="continue-btn continue-btn-secondary">
              浏览分类
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/>
                <path d="M8 4v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="source-ledger-stack">
          {topSources.map((source, index) => (
            <a href={source.url} target="_blank" rel="noopener noreferrer" class="source-ledger-row">
              <span class="source-ledger-rank">0{index + 1}</span>
              <span class="source-ledger-name">{source.name}</span>
              <span class="source-ledger-count">{source.count}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-container">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="footer-logo">AI Signal Surface</span>
          <span class="footer-dot"></span>
          <span class="footer-date">{displayDate}</span>
        </div>
        <p class="footer-meta">
          每日 AI 行业动态聚合 · {hasData ? `${totalCount} 条精选` : '数据加载中'}
          {hasCommunityData && ` · ${communityCount} 条热议`}
        </p>
      </div>
    </div>
  </footer>
  </main>

  <script is:inline>
    const sweepRoot = document.querySelector('[data-category-sweep-root]');
    const sweepControls = Array.from(document.querySelectorAll('[data-category-filter]'));

    if (sweepRoot && sweepControls.length > 0) {
      const sweepPanels = Array.from(sweepRoot.querySelectorAll('[data-category-panel]'));

      const activatePanel = (key) => {
        sweepControls.forEach((control) => {
          const isActive = control.dataset.categoryFilter === key;
          control.classList.toggle('is-active', isActive);
          control.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });

        sweepPanels.forEach((panel) => {
          const isActive = panel.dataset.categoryPanel === key;
          panel.hidden = !isActive;
          panel.classList.toggle('is-active', isActive);
        });
      };

      sweepControls.forEach((control) => {
        control.addEventListener('click', () => activatePanel(control.dataset.categoryFilter || 'all'));
      });

      activatePanel('all');
    }
  </script>

  <style>
    .global-rail {
      position: sticky;
      top: 0;
      z-index: calc(var(--z-sticky) + 10);
      padding: clamp(0.75rem, 2vw, 1.15rem) var(--space-xl) 0;
    }

    .global-rail-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-lg);
      padding: 0.7rem 1rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: var(--radius-full);
      background:
        linear-gradient(180deg, rgba(10, 12, 22, 0.82), rgba(8, 10, 18, 0.62)),
        radial-gradient(circle at left, rgba(255, 92, 92, 0.14), transparent 34%);
      backdrop-filter: blur(26px);
      box-shadow:
        0 12px 44px rgba(0, 0, 0, 0.26),
        inset 0 1px 0 rgba(255, 255, 255, 0.05),
        0 0 40px rgba(38, 216, 255, 0.08);
    }

    .global-rail-brand,
    .global-rail-nav a,
    .hero-status-pill,
    .hero-marquee-link,
    .signal-marquee-card {
      text-decoration: none;
    }

    .global-rail-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      color: var(--text-primary);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-family: var(--font-display);
    }

    .global-rail-brand-mark {
      width: 10px;
      height: 10px;
      border-radius: 9999px;
      background: linear-gradient(135deg, rgba(255, 99, 99, 1), rgba(0, 232, 255, 0.95));
      box-shadow:
        0 0 18px rgba(255, 92, 92, 0.48),
        0 0 22px rgba(0, 232, 255, 0.24);
    }

    .global-rail-status {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      color: rgba(212, 219, 235, 0.72);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      white-space: nowrap;
      font-family: var(--font-mono);
    }

    .global-rail-date {
      color: rgba(248, 250, 255, 0.88);
      font-weight: 600;
    }

    .global-rail-separator {
      color: rgba(255, 255, 255, 0.24);
    }

    .global-rail-nav {
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .global-rail-nav a {
      padding: 0.45rem 0.7rem;
      border-radius: var(--radius-full);
      color: rgba(232, 238, 250, 0.74);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-family: var(--font-display);
      transition:
        color var(--duration-fast) ease,
        background-color var(--duration-fast) ease,
        border-color var(--duration-fast) ease,
        box-shadow var(--duration-fast) ease;
      border: 1px solid transparent;
    }

    .global-rail-nav a:hover {
      color: var(--text-primary);
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 0 0 24px rgba(0, 232, 255, 0.08);
    }

    /* ============================================
       BLOCK 1: HERO - OpenClaw-like Signal Stage
       ============================================ */
    .hero {
      position: relative;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      justify-content: flex-start;
      align-items: center;
      padding: clamp(4.4rem, 6.5vw, 5.8rem) var(--space-xl) var(--space-4xl);
      overflow: hidden;
    }

    .hero-stage {
      position: relative;
      z-index: 2;
      width: min(1040px, 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: clamp(1.5rem, 3vw, 2.5rem);
      text-align: center;
      margin-top: clamp(2.8rem, 6vh, 4.5rem);
    }

    .hero-brand-mark {
      position: relative;
      width: clamp(4.6rem, 9vw, 6rem);
      height: clamp(4.6rem, 9vw, 6rem);
      display: grid;
      place-items: center;
      margin-bottom: 0.5rem;
      animation: heroMarkFloat 7s ease-in-out infinite;
    }

    .hero-brand-core {
      width: 54%;
      height: 54%;
      border-radius: 9999px;
      background:
        radial-gradient(circle at 38% 34%, rgba(255, 244, 244, 0.95), rgba(255, 122, 122, 0.9) 34%, rgba(255, 82, 82, 0.88) 58%, rgba(219, 38, 38, 0.92) 100%);
      box-shadow:
        0 0 28px rgba(255, 87, 87, 0.72),
        0 0 60px rgba(255, 87, 87, 0.34);
    }

    .hero-brand-ring {
      position: absolute;
      inset: 0;
      border-radius: 9999px;
      pointer-events: none;
      opacity: 0.7;
      filter: blur(12px);
    }

    .hero-brand-ring-red {
      background: radial-gradient(circle, rgba(255, 84, 84, 0.3) 0%, transparent 68%);
      transform: scale(1.14);
    }

    .hero-brand-ring-blue {
      background: radial-gradient(circle, rgba(0, 213, 255, 0.2) 0%, transparent 74%);
      transform: translate(18%, 10%) scale(1.32);
    }

    .hero-copy {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      max-width: 56rem;
    }

    .hero-kicker {
      margin: 0;
      color: rgba(255, 122, 122, 0.95);
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-family: var(--font-display);
    }

    .hero-title {
      margin: 0;
      font-size: clamp(4rem, 11vw, 6.9rem);
      line-height: 0.92;
      letter-spacing: -0.06em;
      font-weight: 900;
      font-family: var(--font-display);
      color: var(--text-primary);
      text-wrap: balance;
      text-shadow:
        0 0 42px rgba(255, 86, 86, 0.14),
        0 0 56px rgba(0, 217, 255, 0.12);
    }

    .hero-subtitle {
      margin: 0;
      font-size: clamp(1rem, 2vw, 1.32rem);
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255, 103, 103, 0.94);
      font-family: var(--font-display);
    }

    .hero-lead {
      max-width: 48rem;
      margin: 0;
      color: rgba(223, 230, 246, 0.74);
      font-size: clamp(1rem, 1.45vw, 1.18rem);
      line-height: 1.85;
      text-wrap: balance;
    }

    .hero-status-pill {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.9rem;
      max-width: min(48rem, calc(100vw - 4rem));
      padding: 0.78rem 1.05rem;
      border-radius: 9999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        linear-gradient(180deg, rgba(12, 16, 30, 0.86), rgba(8, 10, 20, 0.72)),
        radial-gradient(circle at 20% 50%, rgba(255, 90, 90, 0.12), transparent 34%);
      color: var(--text-primary);
      box-shadow:
        0 16px 40px rgba(3, 5, 10, 0.26),
        0 0 36px rgba(255, 84, 84, 0.08);
      transition:
        border-color var(--duration-fast) ease,
        transform var(--duration-fast) ease,
        box-shadow var(--duration-fast) ease;
    }

    .hero-status-pill:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 255, 255, 0.18);
      box-shadow:
        0 18px 44px rgba(3, 5, 10, 0.32),
        0 0 44px rgba(255, 84, 84, 0.12),
        0 0 28px rgba(0, 213, 255, 0.08);
    }

    .hero-status-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 3.3rem;
      min-height: 1.85rem;
      padding: 0 0.85rem;
      border-radius: 9999px;
      background: linear-gradient(135deg, rgba(255, 88, 88, 1), rgba(255, 118, 118, 0.94));
      color: #fff5f5;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      box-shadow: 0 0 24px rgba(255, 84, 84, 0.28);
    }

    .hero-status-copy {
      min-width: 0;
      color: rgba(240, 245, 255, 0.86);
      font-size: 0.96rem;
      line-height: 1.45;
      text-align: left;
    }

    .hero-status-arrow {
      color: rgba(255, 255, 255, 0.72);
      font-size: 1.05rem;
      transform: translateX(0);
      transition: transform var(--duration-fast) ease;
    }

    .hero-status-pill:hover .hero-status-arrow {
      transform: translateX(3px);
    }

    .hero-marquee-shell {
      width: 100%;
      padding-top: 0.35rem;
    }

    .hero-marquee-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.15rem;
      padding: 0 0.2rem;
    }

    .hero-marquee-title {
      margin: 0;
      color: rgba(244, 246, 255, 0.96);
      font-size: clamp(1.85rem, 3vw, 2.3rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      font-family: var(--font-display);
      text-align: left;
    }

    .hero-marquee-link {
      color: rgba(255, 95, 95, 0.92);
      font-size: 0.96rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .signal-marquee {
      position: relative;
      overflow: hidden;
      padding: 0 0.25rem;
    }

    .signal-marquee-fade {
      position: absolute;
      top: 0;
      bottom: 0;
      width: min(9vw, 6rem);
      z-index: 2;
      pointer-events: none;
    }

    .signal-marquee-fade-left {
      left: 0;
      background: linear-gradient(90deg, rgba(5, 8, 20, 0.96), transparent);
    }

    .signal-marquee-fade-right {
      right: 0;
      background: linear-gradient(270deg, rgba(5, 8, 20, 0.96), transparent);
    }

    .signal-marquee-track {
      --marquee-step: 23.1rem;
      display: flex;
      gap: 1.25rem;
      width: max-content;
      animation: marqueeOscillate 24s ease-in-out infinite alternate;
      will-change: transform;
    }

    .signal-marquee:hover .signal-marquee-track {
      animation-play-state: paused;
    }

    .signal-marquee-card {
      position: relative;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.95rem;
      align-items: flex-start;
      width: min(21.85rem, calc(100vw - 4rem));
      min-height: 8.9rem;
      padding: 0.95rem 1.05rem;
      border-radius: 1.45rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(10, 14, 26, 0.78), rgba(8, 11, 20, 0.68)),
        radial-gradient(circle at right top, rgba(0, 232, 255, 0.08), transparent 34%);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.04),
        0 20px 42px rgba(0, 0, 0, 0.22);
      color: inherit;
      transition:
        transform var(--duration-fast) ease,
        border-color var(--duration-fast) ease,
        box-shadow var(--duration-fast) ease;
    }

    .signal-marquee-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.18);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.06),
        0 24px 50px rgba(0, 0, 0, 0.28),
        0 0 36px rgba(255, 92, 92, 0.08);
    }

    .signal-marquee-avatar {
      width: 2.55rem;
      height: 2.55rem;
      border-radius: 9999px;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 30% 30%, rgba(255, 144, 144, 0.95), rgba(255, 87, 87, 0.88) 55%, rgba(255, 87, 87, 0.18) 100%);
      color: #fff7f7;
      font-family: var(--font-display);
      font-size: 0.88rem;
      font-weight: 800;
      box-shadow:
        0 0 26px rgba(255, 92, 92, 0.26),
        0 0 18px rgba(255, 92, 92, 0.18);
      flex-shrink: 0;
    }

    .signal-marquee-content {
      display: flex;
      flex-direction: column;
      gap: 0.48rem;
      text-align: left;
      min-width: 0;
    }

    .signal-marquee-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      color: rgba(205, 214, 231, 0.72);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.13em;
      font-family: var(--font-mono);
    }

    .signal-marquee-source {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .signal-marquee-hot {
      color: rgba(255, 129, 129, 0.94);
      white-space: nowrap;
    }

    .signal-marquee-card-title {
      margin: 0;
      color: rgba(247, 249, 255, 0.98);
      font-size: 1.12rem;
      line-height: 1.32;
      font-weight: 700;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
    }

    .signal-marquee-summary {
      margin: 0;
      color: rgba(201, 210, 230, 0.72);
      font-size: 0.88rem;
      line-height: 1.48;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
    }

    .signal-marquee-tags {
      color: rgba(255, 108, 108, 0.88);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-family: var(--font-display);
    }

    .hero-scroll {
      position: absolute;
      bottom: clamp(1rem, 3vw, 2rem);
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
    }

    .scroll-hint {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      color: rgba(216, 225, 242, 0.5);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      animation: fadeInUp 1s ease-out 1s both;
    }

    .scroll-line {
      width: 1px;
      height: 48px;
      background: rgba(255, 255, 255, 0.12);
      position: relative;
      overflow: hidden;
    }

    .scroll-line-progress {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 42%;
      background: linear-gradient(to bottom, rgba(255, 92, 92, 1), transparent);
      animation: scrollProgress 2.5s ease-in-out infinite;
    }

    @keyframes heroMarkFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    @keyframes marqueeOscillate {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(calc(var(--marquee-count) * var(--marquee-step) * -1));
      }
    }

    @keyframes scrollProgress {
      0% { transform: translateY(-100%); }
      100% { transform: translateY(400%); }
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ============================================
       BLOCK: COMMON STYLES - v4 refined
       ============================================ */
    .block {
      position: relative;
      z-index: var(--z-content);
      padding: var(--space-4xl) var(--space-xl);
    }

    .block-container {
      max-width: 1160px;
      margin: 0 auto;
    }

    .block-header {
      display: flex;
      align-items: flex-start;
      gap: var(--space-md);
      margin-bottom: var(--space-2xl);
    }

    .block-header-center {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-sm);
      margin-bottom: var(--space-2xl);
    }

    .header-accent {
      width: 3px;
      height: 32px;
      background: linear-gradient(to bottom, var(--accent-warm), transparent);
      border-radius: var(--radius-full);
      flex-shrink: 0;
    }

    .header-content {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .header-eyebrow {
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--accent-warm);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .header-title {
      font-size: var(--text-2xl);
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      margin: 0;
    }

    .header-desc {
      font-size: var(--text-sm);
      color: var(--text-tertiary);
      margin: var(--space-xs) 0 0;
    }

    /* ============================================
       BLOCK 2: FEATURED - 今日重点 v4 refined
       ============================================ */
    .block-featured {
      background: linear-gradient(
        180deg,
        transparent 0%,
        rgba(251, 158, 75, 0.02) 15%,
        rgba(251, 158, 75, 0.015) 85%,
        transparent 100%
      );
      padding-top: var(--space-5xl);
    }

    .featured-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }

    .featured-card {
      position: relative;
      background: var(--bg-elevated);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: all var(--duration-normal) var(--ease-out);
    }

    .featured-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-card-hover);
      border-color: var(--border-default);
    }

    .featured-card-0 {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
    }

    .featured-card-0 .featured-image {
      aspect-ratio: auto;
      height: 100%;
      min-height: 260px;
    }

    .featured-card-0 .featured-content {
      justify-content: center;
      padding: var(--space-xl);
    }

    .featured-card-0 .featured-title {
      font-size: var(--text-lg);
      line-height: 1.4;
    }

    .featured-card-0 .featured-summary {
      -webkit-line-clamp: 3;
    }

    .featured-link {
      display: contents;
      text-decoration: none;
      color: inherit;
    }

    .featured-image {
      position: relative;
      aspect-ratio: 16 / 10;
      overflow: hidden;
      background: var(--bg-tertiary);
    }

    .featured-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--duration-slow) var(--ease-out);
    }

    .featured-card:hover .featured-image img {
      transform: scale(1.04);
    }

    .featured-image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--accent-warm-soft) 0%, var(--accent-cool-soft) 100%);
    }

    .featured-image-placeholder span {
      font-size: 2rem;
      font-weight: 700;
      color: var(--accent-warm);
      opacity: 0.5;
    }

    .featured-image-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.35) 0%, transparent 55%);
      pointer-events: none;
    }

    .featured-content {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
      padding: var(--space-lg);
    }

    .featured-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: var(--text-xs);
    }

    .featured-source {
      color: var(--text-tertiary);
      font-weight: 500;
    }

    .featured-hot {
      color: var(--accent-warm);
      font-weight: 600;
      padding: var(--space-xs) var(--space-sm);
      background: var(--accent-warm-dim);
      border-radius: var(--radius-full);
      font-size: var(--text-xs);
    }

    .featured-title {
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.45;
      margin: 0;
    }

    .featured-summary {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin: 0;
    }

    .featured-cta {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      margin-top: auto;
      padding-top: var(--space-sm);
      font-size: var(--text-xs);
      font-weight: 500;
      color: var(--accent-warm);
      transition: gap var(--duration-fast) ease;
    }

    .featured-card:hover .featured-cta {
      gap: var(--space-sm);
    }

    .featured-cta svg {
      transition: transform var(--duration-fast) ease;
      width: 14px;
      height: 14px;
    }

    .featured-card:hover .featured-cta svg {
      transform: translate(2px, -2px);
    }

    /* ============================================
       BLOCK 3: CATEGORIES - 分类浏览 v4 refined
       ============================================ */
    .block-categories {
      background: var(--bg-secondary);
      border-top: 1px solid var(--border-subtle);
      border-bottom: 1px solid var(--border-subtle);
    }

    .categories-content {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xl);
    }

    .category-sweep-controls {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-sm);
      margin-top: var(--space-md);
    }

    .category-sweep-control {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      padding: 0.75rem 1rem;
      border-radius: var(--radius-full);
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
      color: var(--text-secondary);
      font: inherit;
      font-size: var(--text-sm);
      cursor: pointer;
      transition:
        border-color var(--duration-fast) ease,
        background-color var(--duration-fast) ease,
        color var(--duration-fast) ease,
        transform var(--duration-fast) ease;
    }

    .category-sweep-control:hover,
    .category-sweep-control.is-active {
      color: var(--text-primary);
      border-color: rgba(255, 159, 67, 0.24);
      background: rgba(255, 159, 67, 0.1);
      transform: translateY(-1px);
    }

    .category-sweep-control-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.75rem;
      min-height: 1.75rem;
      border-radius: 9999px;
      background: rgba(69, 163, 255, 0.12);
      color: var(--accent-cool);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
    }

    .category-sweep-panels {
      position: relative;
    }

    .category-sweep-panel {
      animation: fadeInUp 240ms var(--ease-out);
    }

    .category-sweep-panel[hidden] {
      display: none;
    }

    .category-section {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--border-subtle);
    }

    .category-icon {
      font-size: var(--text-base);
      opacity: 0.7;
    }

    .category-title {
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
      letter-spacing: -0.01em;
    }

    .category-count {
      font-size: var(--text-xs);
      color: var(--text-muted);
      background: var(--bg-tertiary);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-full);
      margin-left: auto;
      font-weight: 500;
    }

    .category-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-md);
    }

    /* ============================================
       BLOCK 4: COMMUNITY - 社区热议 v4 refined
       ============================================ */
    .block-community {
      background: linear-gradient(
        180deg,
        var(--bg-secondary) 0%,
        rgba(165, 180, 252, 0.02) 50%,
        var(--bg-primary) 100%
      );
      border-bottom: 1px solid var(--border-subtle);
    }

    .block-header-community {
      align-items: center;
      text-align: center;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .community-pulse-band {
      padding: var(--space-md);
      border-radius: calc(var(--radius-2xl) + 2px);
      border: 1px solid rgba(158, 169, 255, 0.14);
      background:
        linear-gradient(180deg, rgba(18, 20, 32, 0.84), rgba(10, 12, 18, 0.8)),
        radial-gradient(circle at top, rgba(158, 169, 255, 0.14), transparent 34%);
      box-shadow:
        0 22px 64px rgba(0, 0, 0, 0.34),
        0 0 44px rgba(158, 169, 255, 0.08);
    }

    .header-accent-community {
      background: linear-gradient(to bottom, var(--accent-purple), transparent);
    }

    .community-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .community-card {
      position: relative;
      background: var(--bg-elevated);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: all var(--duration-normal) var(--ease-out);
      animation: cardEnter 0.5s var(--ease-out) backwards;
      animation-delay: var(--delay);
    }

    @keyframes cardEnter {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .community-card:hover {
      transform: translateY(-2px);
      border-color: var(--border-default);
      box-shadow: var(--shadow-card-hover);
    }

    .community-card-inner {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
      padding: var(--space-lg);
    }

    .community-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .community-subreddit {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--accent-purple);
    }

    .community-subreddit svg {
      width: 14px;
      height: 14px;
    }

    .community-hot {
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--accent-warm);
      padding: var(--space-xs) var(--space-sm);
      background: var(--accent-warm-dim);
      border-radius: var(--radius-full);
    }

    .community-title {
      font-size: var(--text-base);
      font-weight: 600;
      line-height: 1.45;
      margin: 0;
    }

    .community-title a {
      color: var(--text-primary);
      text-decoration: none;
      transition: color var(--duration-fast) ease;
    }

    .community-title a:hover {
      color: var(--accent-purple);
    }

    .community-summary {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin: 0;
    }

    .community-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      margin-top: auto;
      padding-top: var(--space-sm);
      font-size: var(--text-xs);
      font-weight: 500;
      color: var(--accent-purple);
      text-decoration: none;
      transition: gap var(--duration-fast) ease;
    }

    .community-link:hover {
      gap: var(--space-sm);
    }

    .community-link svg {
      width: 12px;
      height: 12px;
    }

    .community-footer {
      display: flex;
      justify-content: center;
      margin-top: var(--space-2xl);
    }

    .community-more {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
      background: var(--accent-purple-soft);
      border: 1px solid rgba(165, 180, 252, 0.15);
      border-radius: var(--radius-full);
      color: var(--accent-purple);
      font-size: var(--text-xs);
      font-weight: 500;
      text-decoration: none;
      transition: all var(--duration-normal) var(--ease-out);
    }

    .community-more:hover {
      background: rgba(165, 180, 252, 0.12);
      transform: translateY(-1px);
    }

    /* ============================================
       BLOCK 5: CONTINUE - 继续浏览 v4 refined
       ============================================ */
    .block-continue {
      padding: var(--space-5xl) var(--space-xl);
      position: relative;
      overflow: hidden;
    }

    .source-ledger-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.85fr);
      gap: var(--space-xl);
      align-items: stretch;
    }

    .source-ledger-note,
    .source-ledger-stack {
      position: relative;
      border-radius: var(--radius-2xl);
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: linear-gradient(180deg, rgba(18, 20, 24, 0.82), rgba(10, 12, 16, 0.76));
      overflow: hidden;
    }

    .source-ledger-note {
      padding: var(--space-xl);
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .source-ledger-kicker {
      color: var(--accent-cool);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-family: var(--font-mono);
    }

    .source-ledger-stats {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
      color: var(--text-secondary);
      font-size: var(--text-sm);
    }

    .source-ledger-stats span {
      padding: 0.5rem 0.75rem;
      border-radius: var(--radius-full);
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.04);
    }

    .source-ledger-stack {
      display: flex;
      flex-direction: column;
      padding: var(--space-sm);
      gap: var(--space-xs);
    }

    .source-ledger-row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: var(--space-md);
      padding: var(--space-md);
      border-radius: var(--radius-lg);
      color: inherit;
      text-decoration: none;
      transition:
        background-color var(--duration-fast) ease,
        transform var(--duration-fast) ease;
    }

    .source-ledger-row:hover {
      background: rgba(255, 255, 255, 0.04);
      transform: translateX(2px);
    }

    .source-ledger-rank,
    .source-ledger-count {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: 0.12em;
      color: var(--text-muted);
    }

    .source-ledger-name {
      color: var(--text-primary);
      font-weight: 600;
    }

    .continue-content {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 440px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
    }

    .continue-orb {
      position: absolute;
      width: 280px;
      height: 280px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(
        circle,
        rgba(251, 158, 75, 0.08) 0%,
        transparent 70%
      );
      filter: blur(60px);
      pointer-events: none;
      animation: orbPulse 5s ease-in-out infinite;
    }

    @keyframes orbPulse {
      0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
      50% { opacity: 0.7; transform: translate(-50%, -50%) scale(1.08); }
    }

    .continue-title {
      font-size: var(--text-xl);
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
      letter-spacing: -0.01em;
    }

    .continue-desc {
      font-size: var(--text-sm);
      color: var(--text-tertiary);
      margin: 0;
    }

    .continue-actions {
      display: flex;
      gap: var(--space-sm);
      margin-top: var(--space-sm);
    }

    .continue-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      padding: var(--space-sm) var(--space-md);
      border-radius: var(--radius-full);
      font-size: var(--text-sm);
      font-weight: 500;
      text-decoration: none;
      transition: all var(--duration-normal) var(--ease-out);
    }

    .continue-btn-primary {
      background: var(--accent-warm);
      color: var(--text-inverse);
    }

    .continue-btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px -4px rgba(251, 158, 75, 0.25);
    }

    .continue-btn-secondary {
      background: transparent;
      color: var(--text-secondary);
      border: 1px solid var(--border-default);
    }

    .continue-btn-secondary:hover {
      background: var(--bg-elevated);
      color: var(--text-primary);
      border-color: var(--border-strong);
    }

    /* ============================================
       FOOTER - v4 refined
       ============================================ */
    .site-footer {
      position: relative;
      z-index: var(--z-content);
      padding: var(--space-2xl) var(--space-xl);
      border-top: 1px solid var(--border-subtle);
      background: var(--bg-primary);
    }

    .footer-container {
      max-width: 1160px;
      margin: 0 auto;
    }

    .footer-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
    }

    .footer-brand {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
    }

    .footer-logo {
      font-size: var(--text-sm);
      font-weight: 600;
      color: var(--text-primary);
    }

    .footer-dot {
      width: 3px;
      height: 3px;
      background: var(--accent-warm);
      border-radius: 50%;
    }

    .footer-date {
      font-size: var(--text-xs);
      color: var(--text-tertiary);
    }

    .footer-meta {
      font-size: var(--text-xs);
      color: var(--text-muted);
      margin: 0;
    }

    /* ============================================
       RESPONSIVE
       ============================================ */
    @media (max-width: 1024px) {
      .global-rail-inner {
        flex-wrap: wrap;
        justify-content: center;
      }

      .hero-stage {
        width: min(100%, 960px);
      }

      .hero-copy {
        max-width: 48rem;
      }

      .hero-status-pill {
        width: 100%;
      }

      .featured-grid {
        grid-template-columns: 1fr;
      }

      .source-ledger-grid {
        grid-template-columns: 1fr;
      }

      .featured-card-0 {
        grid-column: span 1;
        grid-template-columns: 1fr;
      }

      .featured-card-0 .featured-image {
        min-height: auto;
        aspect-ratio: 16 / 10;
      }

      .category-cards {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .global-rail {
        padding: var(--space-sm) var(--space-lg) 0;
      }

      .global-rail-inner,
      .global-rail-nav {
        justify-content: center;
      }

      .global-rail-status {
        order: 3;
      }

      .hero {
        padding: 4.8rem var(--space-lg) var(--space-3xl);
      }

      .hero-stage {
        margin-top: 2.2rem;
      }

      .hero-title {
        font-size: clamp(3.4rem, 12vw, 5rem);
      }

      .hero-subtitle {
        font-size: 0.95rem;
      }

      .hero-lead {
        font-size: 1rem;
      }

      .hero-status-pill {
        align-items: flex-start;
        padding: 0.9rem 1rem;
      }

      .hero-status-copy {
        font-size: 0.88rem;
      }

      .hero-marquee-header {
        align-items: flex-start;
      }

      .signal-marquee {
        overflow-x: auto;
        padding-bottom: 0.25rem;
        scrollbar-width: none;
      }

      .signal-marquee::-webkit-scrollbar {
        display: none;
      }

      .signal-marquee-track {
        animation: none;
      }

      .signal-marquee-card {
        width: min(19rem, calc(100vw - 3.4rem));
        min-height: 8.6rem;
      }

      .signal-marquee-fade {
        display: none;
      }

      .block {
        padding: var(--space-3xl) var(--space-lg);
      }

      .featured-grid,
      .category-cards,
      .community-grid {
        grid-template-columns: 1fr;
      }

      .continue-actions {
        flex-direction: column;
        width: 100%;
      }

      .continue-btn {
        justify-content: center;
      }

      .signal-tag-list {
        gap: var(--space-xs);
      }
    }
  </style>
</BaseLayout>
