---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportCard from '../components/ui/ReportCard.astro';
import type { DailyReport, ReportCard as ReportCardType, CommunityItem } from '../types/report';

// ========== 数据读取工具函数 ==========

const EMPTY_DAILY_REPORT: DailyReport = {
  version: '1.0',
  meta: {
    date: new Date().toISOString().split('T')[0],
    edition: 'AI-Daily-Empty',
    generatedAt: new Date().toISOString(),
    totalCount: 0,
    tagStats: {
      model: 0,
      product: 0,
      research: 0,
      industry: 0,
      tool: 0,
      policy: 0,
      event: 0,
      funding: 0,
    },
    editorNote: '暂无今日数据，请稍后刷新或联系管理员。',
  },
  items: [],
  sourceStats: [],
  communityPulse: [],
  communityStats: [],
};

function loadLatestReport(): DailyReport {
  try {
    const latestPath = path.join(process.cwd(), 'data', 'reports', 'latest.json');
    
    if (!fs.existsSync(latestPath)) {
      return EMPTY_DAILY_REPORT;
    }

    const content = fs.readFileSync(latestPath, 'utf-8');
    const data = JSON.parse(content) as DailyReport;

    if (!data || typeof data !== 'object') {
      return EMPTY_DAILY_REPORT;
    }

    if (!Array.isArray(data.items)) {
      data.items = [];
    }

    if (!data.meta) {
      data.meta = EMPTY_DAILY_REPORT.meta;
    }

    return data;
  } catch {
    return EMPTY_DAILY_REPORT;
  }
}

// ========== 加载数据 ==========

const report = loadLatestReport();
const { meta, items, sourceStats, communityPulse, communityStats } = report;

// 确保 communityPulse 和 communityStats 存在
const safeCommunityPulse = communityPulse || [];
const safeCommunityStats = communityStats || [];

// 按 featured 和 hotScore 排序主资讯
const sortedItems = [...items].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return (b.hotScore || 0) - (a.hotScore || 0);
});

// 展示全部资讯
const displayItems = sortedItems;

// 社区热议按 hotScore 排序
const sortedCommunity = [...safeCommunityPulse].sort((a, b) => {
  return (b.hotScore || 0) - (a.hotScore || 0);
});

// 社区热议最多展示 4 条
const displayCommunity = sortedCommunity.slice(0, 4);

// 是否有数据
const hasData = items.length > 0;
const hasCommunityData = safeCommunityPulse.length > 0;

// 统计数据
const totalCount = meta.totalCount;
const communityCount = meta.communityCount || safeCommunityPulse.length;
const sourceCount = sourceStats?.length || new Set(items.map(i => i.source)).size || 12;

// 格式化日期
const displayDate = new Date(meta.date || Date.now()).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long'
});
---

<BaseLayout title="AI Daily Report - 每日 AI 行业动态">
  <!-- Liquid Metal Background Effect -->
  <div class="liquid-bg" aria-hidden="true">
    <div class="liquid-blob blob-1"></div>
    <div class="liquid-blob blob-2"></div>
    <div class="liquid-blob blob-3"></div>
    <div class="liquid-blob blob-4"></div>
    <div class="liquid-shine"></div>
    <div class="chrome-gradient"></div>
    <div class="metallic-noise"></div>
  </div>

  <!-- Hero Section - 产品化重构 -->
  <section class="hero">
    <div class="hero-content">
      <!-- 产品标识徽章 -->
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        <span class="badge-text">Live Intelligence</span>
      </div>
      
      <!-- 主标题 - 更产品化的表达 -->
      <div class="hero-title-wrapper">
        <h1 class="hero-title">
          <span class="title-main">AI Daily</span>
          <span class="title-divider"></span>
          <span class="title-sub">Report</span>
        </h1>
        <p class="hero-tagline">全球 AI 动态 · 每日精选</p>
      </div>
      
      <!-- 日期展示 -->
      <div class="hero-date">
        <span class="date-line"></span>
        <span class="date-text">{displayDate}</span>
        <span class="date-line"></span>
      </div>
      
      <!-- 数据指标 - 产品化数据展示 -->
      <div class="hero-stats">
        <div class="stat-card">
          <span class="stat-value" data-count={totalCount}>{hasData ? totalCount : '-'}</span>
          <span class="stat-label">今日精选</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{sourceCount}+</span>
          <span class="stat-label">优质信源</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" data-count={communityCount}>{hasCommunityData ? communityCount : '-'}</span>
          <span class="stat-label">社区热议</span>
        </div>
      </div>
    </div>
    
    <!-- 滚动提示 -->
    <div class="hero-scroll">
      <div class="scroll-indicator">
        <span class="scroll-text">探索更多</span>
        <div class="scroll-line"></div>
      </div>
    </div>
  </section>

  <!-- Reports Section - 主资讯 -->
  <section class="reports-section" id="reports">
    <div class="section-header">
      <div class="section-badge">
        <span class="badge-icon">◆</span>
        <span>Featured</span>
      </div>
      <h2 class="section-title">今日精选</h2>
      <p class="section-desc">
        {hasData 
          ? `从全球 ${sourceCount}+ AI 信源中精选的 ${totalCount} 条高质量内容`
          : meta.editorNote || '暂无今日数据，请稍后刷新'
        }
      </p>
    </div>
    
    {hasData ? (
      <div class="reports-grid">
        {displayItems.map((item, index) => (
          <ReportCard 
            id={item.id}
            title={item.title}
            summary={item.summary}
            source={item.source}
            sourceUrl={item.sourceUrl}
            publishedAt={item.publishedAt}
            imageUrl={item.imageUrl}
            tags={item.tags}
            index={index}
          />
        ))}
      </div>
    ) : (
      <!-- 无数据时的兜底状态 -->
      <div class="empty-state">
        <div class="empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3 class="empty-title">正在整理今日 AI 资讯</h3>
        <p class="empty-desc">{meta.editorNote || '数据正在准备中，请稍后刷新页面'}</p>
      </div>
    )}
    
    {hasData && (
      <div class="section-footer">
        <span class="footer-note">已展示全部 {displayItems.length} 条精选内容</span>
      </div>
    )}
  </section>

  <!-- Community Pulse Section - 社区热议 -->
  {hasCommunityData && (
    <section class="community-section" id="community">
      <div class="section-header community-header">
        <div class="section-badge community-badge">
          <span class="badge-icon">◉</span>
          <span>Community</span>
        </div>
        <h2 class="section-title community-title">社区热议</h2>
        <p class="section-desc community-desc">
          来自 Reddit AI 社区的热门讨论与深度观点
        </p>
      </div>
      
      <div class="community-grid">
        {displayCommunity.map((item, index) => (
          <ReportCard 
            id={item.id}
            title={item.title}
            summary={item.summary}
            source={item.source}
            sourceUrl={item.sourceUrl}
            publishedAt={item.publishedAt}
            imageUrl={item.imageUrl}
            tags={item.tags}
            index={index}
            subreddit={item.subreddit}
            discussionUrl={item.discussionUrl}
            isCommunity={true}
          />
        ))}
      </div>
      
      <div class="section-footer">
        <a 
          href="https://www.reddit.com/r/artificial/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="community-link"
        >
          <span>查看更多 Reddit 讨论</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </section>
  )}

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-content">
      <p class="footer-brand">AI Daily Report</p>
      <p class="footer-meta">
        {hasData 
          ? `本期精选 ${totalCount} 条资讯${hasCommunityData ? ` · ${communityCount} 条社区热议` : ''}`
          : '精选值得关注的 AI 动态'
        }
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ===== HERO SECTION - 产品化重构 ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: var(--space-2xl) var(--space-xl);
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xl);
  }

  /* 产品徽章 */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-md);
    background: var(--surface-glass);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow-sm);
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--accent-success);
    border-radius: 50%;
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  /* 标题区域 */
  .hero-title-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .hero-title {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .title-main {
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--lm-graphite) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .title-divider {
    width: 2px;
    height: 0.8em;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--lm-steel),
      transparent
    );
  }

  .title-sub {
    font-weight: 300;
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    font-weight: 400;
    letter-spacing: 0.1em;
    margin: 0;
  }

  /* 日期展示 */
  .hero-date {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .date-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--lm-steel),
      transparent
    );
  }

  /* 数据指标卡片 */
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
    padding: var(--space-xl);
    background: var(--surface-glass);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-2xl);
    backdrop-filter: blur(20px);
    box-shadow: 
      var(--shadow-md),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    min-width: 80px;
  }

  .stat-value {
    font-size: var(--text-3xl);
    font-weight: 700;
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--lm-iridescent) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* 滚动提示 */
  .hero-scroll {
    position: absolute;
    bottom: var(--space-2xl);
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .scroll-text {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(
      to bottom,
      var(--lm-graphite),
      transparent
    );
    animation: scrollBreathe 2s ease-in-out infinite;
  }

  @keyframes scrollBreathe {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 0.8; transform: scaleY(1); }
  }

  /* ===== SECTIONS - 统一区块样式 ===== */
  .reports-section,
  .community-section {
    position: relative;
    z-index: 2;
    padding: var(--space-4xl) var(--space-xl);
    max-width: 1400px;
    margin: 0 auto;
  }

  .community-section {
    border-top: 1px solid var(--border-subtle);
    margin-top: var(--space-2xl);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  /* 区块徽章 */
  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-md);
    background: rgba(102, 157, 246, 0.08);
    border: 1px solid rgba(102, 157, 246, 0.2);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--lm-iridescent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .community-badge {
    background: rgba(234, 67, 53, 0.06);
    border-color: rgba(234, 67, 53, 0.2);
    color: var(--accent-error);
  }

  .badge-icon {
    font-size: 0.8em;
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.01em;
  }

  .community-title {
    color: var(--text-primary);
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: var(--text-base);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .community-desc {
    color: var(--text-secondary);
  }

  /* 内容网格 */
  .reports-grid,
  .community-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .reports-grid,
    .community-grid {
      grid-template-columns: 1fr;
    }
    
    .hero-stats {
      flex-direction: column;
      gap: var(--space-lg);
      padding: var(--space-lg);
    }
    
    .stat-card {
      min-width: auto;
    }
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-4xl) var(--space-xl);
    text-align: center;
    background: var(--surface-elevated);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-2xl);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow-md);
  }

  .empty-icon {
    color: var(--lm-steel);
    margin-bottom: var(--space-lg);
  }

  .empty-title {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .empty-desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    max-width: 360px;
  }

  /* ===== SECTION FOOTER ===== */
  .section-footer {
    display: flex;
    justify-content: center;
    padding-top: var(--space-2xl);
  }

  .footer-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    padding: var(--space-sm) var(--space-lg);
    background: var(--surface-glass);
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
  }

  /* 社区链接 */
  .community-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    background: rgba(234, 67, 53, 0.06);
    border: 1px solid rgba(234, 67, 53, 0.25);
    border-radius: var(--radius-full);
    color: var(--accent-error);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-metallic);
  }

  .community-link:hover {
    background: rgba(234, 67, 53, 0.1);
    border-color: var(--accent-error);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(234, 67, 53, 0.15);
  }

  .community-link svg {
    transition: transform var(--duration-fast) ease;
  }

  .community-link:hover svg {
    transform: translate(2px, -2px);
  }

  /* ===== FOOTER ===== */
  .site-footer {
    position: relative;
    z-index: 2;
    padding: var(--space-3xl) var(--space-xl);
    border-top: 1px solid var(--border-subtle);
    margin-top: var(--space-2xl);
  }

  .footer-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-brand {
    font-size: var(--text-lg);
    font-weight: 600;
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--lm-iridescent) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-meta {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
</style>
