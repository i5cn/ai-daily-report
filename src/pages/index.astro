---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportCard from '../components/ui/ReportCard.astro';
import type { DailyReport, ReportCard as ReportCardType, CommunityItem } from '../types/report';

// ========== 数据读取工具函数 ==========

const EMPTY_DAILY_REPORT: DailyReport = {
  version: '1.0',
  meta: {
    date: new Date().toISOString().split('T')[0],
    edition: 'AI-Daily-Empty',
    generatedAt: new Date().toISOString(),
    totalCount: 0,
    tagStats: {
      model: 0,
      product: 0,
      research: 0,
      industry: 0,
      tool: 0,
      policy: 0,
      event: 0,
      funding: 0,
    },
    editorNote: '暂无今日数据，请稍后刷新或联系管理员。',
  },
  items: [],
  sourceStats: [],
  communityPulse: [],
  communityStats: [],
};

function loadLatestReport(): DailyReport {
  try {
    const latestPath = path.join(process.cwd(), 'data', 'reports', 'latest.json');
    
    if (!fs.existsSync(latestPath)) {
      return EMPTY_DAILY_REPORT;
    }

    const content = fs.readFileSync(latestPath, 'utf-8');
    const data = JSON.parse(content) as DailyReport;

    if (!data || typeof data !== 'object') {
      return EMPTY_DAILY_REPORT;
    }

    if (!Array.isArray(data.items)) {
      data.items = [];
    }

    if (!data.meta) {
      data.meta = EMPTY_DAILY_REPORT.meta;
    }

    return data;
  } catch {
    return EMPTY_DAILY_REPORT;
  }
}

// ========== 加载数据 ==========

const report = loadLatestReport();
const { meta, items, sourceStats, communityPulse, communityStats } = report;

// 确保 communityPulse 和 communityStats 存在
const safeCommunityPulse = communityPulse || [];
const safeCommunityStats = communityStats || [];

// 按 hotScore 排序
const sortedItems = [...items].sort((a, b) => (b.hotScore || 0) - (a.hotScore || 0));

// ========== 数据分组 ==========

// 今日重点：取 hotScore 最高的 3 条
const featuredItems = sortedItems.slice(0, 3);

// 按标签分类
const itemsByTag = {
  model: sortedItems.filter(i => i.tags?.includes('model')).slice(0, 3),
  product: sortedItems.filter(i => i.tags?.includes('product')).slice(0, 3),
  research: sortedItems.filter(i => i.tags?.includes('research')).slice(0, 3),
  industry: sortedItems.filter(i => i.tags?.includes('industry')).slice(0, 3),
};

// 社区热议按 hotScore 排序，取前 4 条
const sortedCommunity = [...safeCommunityPulse].sort((a, b) => {
  return (b.hotScore || 0) - (a.hotScore || 0);
}).slice(0, 4);

// 是否有数据
const hasData = items.length > 0;
const hasCommunityData = safeCommunityPulse.length > 0;

// 统计数据
const totalCount = meta.totalCount;
const communityCount = meta.communityCount || safeCommunityPulse.length;
const sourceCount = sourceStats?.length || new Set(items.map(i => i.source)).size || 12;

// 格式化日期
const displayDate = new Date(meta.date || Date.now()).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long'
});

const shortDate = new Date(meta.date || Date.now()).toLocaleDateString('zh-CN', {
  month: 'short',
  day: 'numeric'
});

// 标签中文映射
const tagLabels: Record<string, string> = {
  model: '模型',
  product: '产品',
  research: '研究',
  industry: '行业',
  tool: '工具',
  policy: '政策',
};

const tagIcons: Record<string, string> = {
  model: '⚡',
  product: '✦',
  research: '◈',
  industry: '◉',
  tool: '⚙',
  policy: '◆',
};
---

<BaseLayout title="AI Daily Report - 每日 AI 行业动态">
  <!-- Stage Background -->
  <div class="stage-bg" aria-hidden="true">
    <div class="stage-spotlight"></div>
    <div class="stage-ambient-cool"></div>
    <div class="stage-ambient-purple"></div>
    <div class="stage-depth"></div>
    <div class="stage-particles"></div>
    <div class="stage-texture"></div>
    <div class="stage-grid"></div>
  </div>

  <!-- ========== BLOCK 1: HERO - 舞台首屏 ========== -->
  <section class="hero">
    <div class="hero-stage">
      <!-- 顶部日期标签 -->
      <div class="hero-eyebrow">
        <span class="eyebrow-badge">
          <span class="badge-dot"></span>
          <span>每日更新</span>
        </span>
        <span class="eyebrow-divider">·</span>
        <span class="eyebrow-date">{shortDate}</span>
      </div>
      
      <!-- 主标题区 -->
      <div class="hero-title-group">
        <h1 class="hero-title">
          <span class="title-line">AI Daily</span>
          <span class="title-line title-line-accent">Report</span>
        </h1>
        <p class="hero-subtitle">
          追踪 AI 世界的脉搏
          <span class="subtitle-line">每日精选 {hasData ? totalCount : '-'} 条高质量资讯</span>
        </p>
      </div>
      
      <!-- 数据指标 -->
      <div class="hero-metrics">
        <div class="metric-item">
          <span class="metric-value">{hasData ? totalCount : '-'}</span>
          <span class="metric-label">精选资讯</span>
        </div>
        <div class="metric-item">
          <span class="metric-value">{sourceCount}+</span>
          <span class="metric-label">信源</span>
        </div>
        <div class="metric-item">
          <span class="metric-value">{hasCommunityData ? communityCount : '-'}</span>
          <span class="metric-label">社区热议</span>
        </div>
      </div>
    </div>
    
    <!-- 滚动指示 -->
    <div class="hero-scroll">
      <div class="scroll-hint">
        <span>向下探索</span>
        <div class="scroll-line">
          <div class="scroll-line-progress"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BLOCK 2: 今日重点 - 焦点区域 ========== -->
  {hasData && featuredItems.length > 0 && (
    <section class="block block-featured" id="featured">
      <div class="block-container">
        <header class="block-header">
          <div class="header-accent"></div>
          <div class="header-content">
            <span class="header-eyebrow">今日焦点</span>
            <h2 class="header-title">重点资讯</h2>
          </div>
        </header>
        
        <div class="featured-grid">
          {featuredItems.map((item, index) => (
            <article class={`featured-card featured-card-${index}`}>
              <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer" class="featured-link">
                <div class="featured-image">
                  {item.imageUrl ? (
                    <img src={item.imageUrl} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                  ) : (
                    <div class="featured-image-placeholder">
                      <span>{item.title.slice(0, 2).toUpperCase()}</span>
                    </div>
                  )}
                  <div class="featured-image-overlay"></div>
                </div>
                <div class="featured-content">
                  <div class="featured-meta">
                    <span class="featured-source">{item.source}</span>
                    <span class="featured-hot" style={`--hot-level: ${Math.min((item.hotScore || 50) / 100, 1)}`}>
                      {item.hotScore || 50}°
                    </span>
                  </div>
                  <h3 class="featured-title">{item.title}</h3>
                  <p class="featured-summary">{item.summary}</p>
                  <div class="featured-cta">
                    <span>阅读全文</span>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========== BLOCK 3: 主资讯分组 - 分类节奏 ========== -->
  {hasData && (
    <section class="block block-categories" id="categories">
      <div class="block-container">
        <header class="block-header block-header-center">
          <span class="header-eyebrow">分类浏览</span>
          <h2 class="header-title">精选资讯</h2>
          <p class="header-desc">{displayDate} · 共 {totalCount} 条</p>
        </header>
        
        <div class="categories-content">
          {Object.entries(itemsByTag).map(([tag, tagItems]) => (
            tagItems.length > 0 && (
              <div class="category-section">
                <div class="category-header">
                  <span class="category-icon">{tagIcons[tag] || '◆'}</span>
                  <h3 class="category-title">{tagLabels[tag] || tag}</h3>
                  <span class="category-count">{tagItems.length}</span>
                </div>
                <div class="category-cards">
                  {tagItems.map((item, index) => (
                    <ReportCard 
                      id={item.id}
                      title={item.title}
                      summary={item.summary}
                      source={item.source}
                      sourceUrl={item.sourceUrl}
                      publishedAt={item.publishedAt}
                      imageUrl={item.imageUrl}
                      tags={item.tags}
                      index={index}
                      variant="compact"
                    />
                  ))}
                </div>
              </div>
            )
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========== BLOCK 4: 社区热议 - 社交节奏 ========== -->
  {hasCommunityData && sortedCommunity.length > 0 && (
    <section class="block block-community" id="community">
      <div class="block-container">
        <header class="block-header block-header-community">
          <div class="header-accent header-accent-community"></div>
          <div class="header-content">
            <span class="header-eyebrow">Reddit</span>
            <h2 class="header-title">社区热议</h2>
          </div>
          <p class="header-desc">来自 AI 社区的热门讨论</p>
        </header>
        
        <div class="community-grid">
          {sortedCommunity.map((item, index) => (
            <article class="community-card" style={`--delay: ${index * 100}ms`}>
              <div class="community-card-inner">
                <div class="community-meta">
                  <span class="community-subreddit">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 3.48 2.737 0 2.384-2.153 2.625-2.178 2.641l-.003.002c-.418.191-.706.159-1.122.241v.001c-.476.094-.798.137-1.179.137-.644 0-1.236-.093-1.754-.286-.647-.238-1.186-.59-1.592-1.035-.406-.445-.7-.978-.873-1.592a4.27 4.27 0 0 1-.077-1.887c.124-.511.355-.974.686-1.374.331-.4.753-.718 1.256-.949.503-.231 1.075-.347 1.703-.347.29 0 .574.02.848.061.273.04.544.104.81.188l.462-2.164h.002l.393-1.846c.032-.155.16-.27.319-.27h.002l2.53.533zm-5.077 5.827c-.521 0-.949.115-1.274.345-.325.23-.56.55-.695.956a2.49 2.49 0 0 0 .049 1.216c.125.41.349.752.668 1.019.319.267.72.401 1.195.401.277 0 .535-.04.772-.117.237-.078.46-.202.668-.37v-.001l.003-.002c.234-.19.408-.437.522-.737a2.22 2.22 0 0 0 .054-1.06 1.962 1.962 0 0 0-.597-.96 1.661 1.661 0 0 0-1.149-.425c-.166 0-.324.015-.472.044l-.016.003a1.94 1.94 0 0 0-.332.076l-.007.002h-.002c-.029.008-.057.018-.084.029l-.008.003zm8.58 1.17a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75zm-10.01 0a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75z"/>
                    </svg>
                    r/{item.subreddit}
                  </span>
                  <span class="community-hot">{item.hotScore}°</span>
                </div>
                <h3 class="community-title">
                  <a href={item.discussionUrl || item.sourceUrl} target="_blank" rel="noopener noreferrer">
                    {item.title}
                  </a>
                </h3>
                <p class="community-summary">{item.summary}</p>
                <a href={item.discussionUrl || item.sourceUrl} target="_blank" rel="noopener noreferrer" class="community-link">
                  查看讨论
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
        
        <div class="community-footer">
          <a href="https://www.reddit.com/r/artificial/" target="_blank" rel="noopener noreferrer" class="community-more">
            更多 Reddit 讨论
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ========== BLOCK 5: 继续浏览 - 行动召唤 ========== -->
  <section class="block block-continue" id="continue">
    <div class="block-container">
      <div class="continue-content">
        <div class="continue-orb" aria-hidden="true"></div>
        <h2 class="continue-title">探索更多</h2>
        <p class="continue-desc">
          {hasData 
            ? `今日已精选 ${totalCount} 条资讯，来自 ${sourceCount}+ 个信源`
            : '每日更新 AI 行业最新动态'
          }
        </p>
        <div class="continue-actions">
          <a href="#featured" class="continue-btn continue-btn-primary">
            回到顶部
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M8 12V4M4 8l4-4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href={`/archive`} class="continue-btn continue-btn-secondary">
            浏览历史
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 4v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-container">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="footer-logo">AI Daily Report</span>
          <span class="footer-dot"></span>
          <span class="footer-date">{displayDate}</span>
        </div>
        <p class="footer-meta">
          每日 AI 行业动态聚合 · {hasData ? `${totalCount} 条精选` : '数据加载中'}
          {hasCommunityData && ` · ${communityCount} 条热议`}
        </p>
      </div>
    </div>
  </footer>

  <style>
    /* ============================================
       BLOCK 1: HERO - 舞台首屏
       ============================================ */
    .hero {
      position: relative;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: var(--space-2xl);
      overflow: hidden;
    }

    .hero-stage {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 680px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2xl);
    }

    /* Eyebrow */
    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      font-size: var(--text-sm);
      color: var(--text-tertiary);
    }

    .eyebrow-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      padding: var(--space-xs) var(--space-sm);
      background: var(--accent-warm-dim);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-full);
      font-weight: 500;
      color: var(--accent-warm);
    }

    .badge-dot {
      width: 6px;
      height: 6px;
      background: var(--accent-warm);
      border-radius: 50%;
      animation: dotPulse 2s ease-in-out infinite;
      box-shadow: 0 0 8px var(--accent-warm);
    }

    @keyframes dotPulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    .eyebrow-divider {
      color: var(--text-muted);
    }

    .eyebrow-date {
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    /* Title Group */
    .hero-title-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
    }

    .hero-title {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.125em;
      font-size: clamp(3.5rem, 10vw, 6rem);
      font-weight: 800;
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin: 0;
    }

    .title-line {
      display: block;
      color: var(--text-primary);
      text-shadow: 0 0 60px rgba(251, 158, 75, 0.15);
    }

    .title-line-accent {
      background: linear-gradient(
        135deg,
        var(--accent-warm) 0%,
        var(--accent-warm-light) 60%,
        var(--accent-cool) 100%
      );
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 30px rgba(251, 158, 75, 0.2));
    }

    .hero-subtitle {
      font-size: var(--text-lg);
      color: var(--text-secondary);
      font-weight: 400;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
      letter-spacing: 0.01em;
    }

    .subtitle-line {
      font-size: var(--text-sm);
      color: var(--text-tertiary);
      font-weight: 500;
    }

    /* Metrics */
    .hero-metrics {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-xl);
      padding: var(--space-md) var(--space-xl);
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-xl);
      backdrop-filter: blur(16px);
    }

    .metric-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
      min-width: 72px;
    }

    .metric-value {
      font-size: var(--text-2xl);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1;
      background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .metric-label {
      font-size: var(--text-xs);
      color: var(--text-tertiary);
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    /* Scroll Hint */
    .hero-scroll {
      position: absolute;
      bottom: var(--space-2xl);
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
    }

    .scroll-hint {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      color: var(--text-muted);
      font-size: var(--text-xs);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      animation: fadeInUp 1s ease-out 1s both;
    }

    .scroll-line {
      width: 1px;
      height: 48px;
      background: var(--border-subtle);
      position: relative;
      overflow: hidden;
    }

    .scroll-line-progress {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 35%;
      background: linear-gradient(to bottom, var(--accent-warm), transparent);
      animation: scrollProgress 2.5s ease-in-out infinite;
    }

    @keyframes scrollProgress {
      0% { transform: translateY(-100%); }
      100% { transform: translateY(400%); }
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ============================================
       BLOCK: COMMON STYLES - v4 refined
       ============================================ */
    .block {
      position: relative;
      z-index: var(--z-content);
      padding: var(--space-4xl) var(--space-xl);
    }

    .block-container {
      max-width: 1160px;
      margin: 0 auto;
    }

    .block-header {
      display: flex;
      align-items: flex-start;
      gap: var(--space-md);
      margin-bottom: var(--space-2xl);
    }

    .block-header-center {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-sm);
      margin-bottom: var(--space-2xl);
    }

    .header-accent {
      width: 3px;
      height: 32px;
      background: linear-gradient(to bottom, var(--accent-warm), transparent);
      border-radius: var(--radius-full);
      flex-shrink: 0;
    }

    .header-content {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .header-eyebrow {
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--accent-warm);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .header-title {
      font-size: var(--text-2xl);
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      margin: 0;
    }

    .header-desc {
      font-size: var(--text-sm);
      color: var(--text-tertiary);
      margin: var(--space-xs) 0 0;
    }

    /* ============================================
       BLOCK 2: FEATURED - 今日重点 v4 refined
       ============================================ */
    .block-featured {
      background: linear-gradient(
        180deg,
        transparent 0%,
        rgba(251, 158, 75, 0.02) 15%,
        rgba(251, 158, 75, 0.015) 85%,
        transparent 100%
      );
      padding-top: var(--space-5xl);
    }

    .featured-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }

    .featured-card {
      position: relative;
      background: var(--bg-elevated);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: all var(--duration-normal) var(--ease-out);
    }

    .featured-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-card-hover);
