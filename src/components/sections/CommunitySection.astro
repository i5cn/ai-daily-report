---
import type { CommunityItem } from '../../types/report';

export interface Props {
  sortedCommunity: CommunityItem[];
}

const { sortedCommunity } = Astro.props;
---

<section class="block block-community" id="community" aria-labelledby="community-pulse-title">
  <div class="block-container">
    <header class="block-header block-header-community">
      <div class="header-accent header-accent-community"></div>
      <div class="header-content">
        <span class="header-eyebrow">Reddit</span>
        <h2 class="header-title" id="community-pulse-title">Community Pulse</h2>
      </div>
      <p class="header-desc">来自 AI 社区的热门讨论</p>
    </header>
    
    <div class="community-pulse-band">
      <div class="community-grid">
        {sortedCommunity.map((item, index) => (
          <article class="community-card" style={`--delay: ${index * 100}ms`}>
            <div class="community-card-inner">
              <div class="community-meta">
                <span class="community-subreddit">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 3.48 2.737 0 2.384-2.153 2.625-2.178 2.641l-.003.002c-.418.191-.706.159-1.122.241v.001c-.476.094-.798.137-1.179.137-.644 0-1.236-.093-1.754-.286-.647-.238-1.186-.59-1.592-1.035-.406-.445-.7-.978-.873-1.592a4.27 4.27 0 0 1-.077-1.887c.124-.511.355-.974.686-1.374.331-.4.753-.718 1.256-.949.503-.231 1.075-.347 1.703-.347.29 0 .574.02.848.061.273.04.544.104.81.188l.462-2.164h.002l.393-1.846c.032-.155.16-.27.319-.27h.002l2.53.533zm-5.077 5.827c-.521 0-.949.115-1.274.345-.325.23-.56.55-.695.956a2.49 2.49 0 0 0 .049 1.216c.125.41.349.752.668 1.019.319.267.72.401 1.195.401.277 0 .535-.04.772-.117.237-.078.46-.202.668-.37v-.001l.003-.002c.234-.19.408-.437.522-.737a2.22 2.22 0 0 0 .054-1.06 1.962 1.962 0 0 0-.597-.96 1.661 1.661 0 0 0-1.149-.425c-.166 0-.324.015-.472.044l-.016.003a1.94 1.94 0 0 0-.332.076l-.007.002h-.002c-.029.008-.057.018-.084.029l-.008.003zm8.58 1.17a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75zm-10.01 0a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75z"/>
                  </svg>
                  r/{item.subreddit}
                </span>
                <span class="community-hot">{item.hotScore}°</span>
              </div>
              <h3 class="community-title">
                <a href={item.discussionUrl || item.sourceUrl} target="_blank" rel="noopener noreferrer">
                  {item.title}
                </a>
              </h3>
              <p class="community-summary">{item.summary}</p>
              <a href={item.discussionUrl || item.sourceUrl} target="_blank" rel="noopener noreferrer" class="community-link">
                查看讨论
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
    
    <div class="community-footer">
      <a href="https://www.reddit.com/r/artificial/" target="_blank" rel="noopener noreferrer" class="community-more">
        更多 Reddit 讨论
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .block {
    position: relative;
    z-index: var(--z-content);
    padding: var(--space-4xl) var(--space-xl);
  }

  .block-container {
    max-width: 1160px;
    margin: 0 auto;
  }

  .block-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .block-header-community {
    align-items: center;
    text-align: center;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .header-accent {
    width: 3px;
    height: 32px;
    background: linear-gradient(to bottom, var(--accent-warm), transparent);
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .header-accent-community {
    background: linear-gradient(to bottom, var(--accent-purple), transparent);
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .header-eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-warm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .header-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .header-desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin: var(--space-xs) 0 0;
  }

  .block-community {
    background: linear-gradient(
      180deg,
      var(--bg-secondary) 0%,
      rgba(165, 180, 252, 0.02) 50%,
      var(--bg-primary) 100%
    );
    border-bottom: 1px solid var(--border-subtle);
  }

  .community-pulse-band {
    padding: var(--space-md);
    border-radius: calc(var(--radius-2xl) + 2px);
    border: 1px solid rgba(158, 169, 255, 0.14);
    background:
      linear-gradient(180deg, rgba(18, 20, 32, 0.84), rgba(10, 12, 18, 0.8)),
      radial-gradient(circle at top, rgba(158, 169, 255, 0.14), transparent 34%);
    box-shadow:
      0 22px 64px rgba(0, 0, 0, 0.34),
      0 0 44px rgba(158, 169, 255, 0.08);
  }

  .community-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  
  @media (max-width: 992px) {
    .community-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 640px) {
    .community-grid {
      grid-template-columns: 1fr;
    }
  }

  .community-card {
    position: relative;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-out);
    animation: cardEnter 0.5s var(--ease-out) backwards;
    animation-delay: var(--delay);
  }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .community-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-default);
    box-shadow: var(--shadow-card-hover);
  }

  .community-card-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
  }

  .community-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .community-subreddit {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-purple);
  }

  .community-subreddit svg {
    width: 14px;
    height: 14px;
  }

  .community-hot {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-warm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--accent-warm-dim);
    border-radius: var(--radius-full);
  }

  .community-title {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.45;
    margin: 0;
  }

  .community-title a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .community-title a:hover {
    color: var(--accent-purple);
  }

  .community-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .community-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: auto;
    padding-top: var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--accent-purple);
    text-decoration: none;
    transition: gap var(--duration-fast) ease;
  }

  .community-link:hover {
    gap: var(--space-sm);
  }

  .community-link svg {
    width: 12px;
    height: 12px;
  }

  .community-footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-2xl);
  }

  .community-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--accent-purple-soft);
    border: 1px solid rgba(165, 180, 252, 0.15);
    border-radius: var(--radius-full);
    color: var(--accent-purple);
    font-size: var(--text-xs);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .community-more:hover {
    background: rgba(165, 180, 252, 0.12);
    transform: translateY(-1px);
  }

  @media (max-width: 1024px) {
    .community-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .block {
      padding: var(--space-3xl) var(--space-lg);
    }
  }
</style>
