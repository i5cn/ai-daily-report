---
import ReportCard from '../ui/ReportCard.astro';
import type { ReportCard as ReportCardType } from '../../types/report';

export interface Props {
  displayDate: string;
  totalCount: number;
  sweepCategories: Array<{
    key: string;
    label: string;
    icon: string;
    count: number;
    items: ReportCardType[];
  }>;
}

const { displayDate, totalCount, sweepCategories } = Astro.props;
---

<section class="block block-categories" id="categories" aria-labelledby="category-sweep-title">
  <div class="block-container">
    <header class="block-header block-header-center">
      <span class="header-eyebrow">分类浏览</span>
      <h2 class="header-title" id="category-sweep-title">Category Sweep</h2>
      <p class="header-desc">{displayDate} · 共 {totalCount} 条</p>
      <div class="category-sweep-controls" aria-label="分类筛选">
        <button type="button" class="category-sweep-control is-active" data-category-filter="all" aria-pressed="true">
          全部
        </button>
        {sweepCategories.map((category) => (
          <button
            type="button"
            class="category-sweep-control"
            data-category-filter={category.key}
            aria-pressed="false"
          >
            <span>{category.icon} {category.label}</span>
            <span class="category-sweep-control-count">{category.count}</span>
          </button>
        ))}
      </div>
    </header>
    
    <div class="category-sweep-panels" data-category-sweep-root>
      <div class="category-sweep-panel is-active" data-category-panel="all">
        <div class="categories-content">
          {sweepCategories.map((category) => (
            <div class="category-section">
              <div class="category-header">
                <span class="category-icon">{category.icon}</span>
                <h3 class="category-title">{category.label}</h3>
                <span class="category-count">{category.count}</span>
              </div>
              <div class="category-cards">
                {category.items.map((item, index) => (
                  <ReportCard 
                    id={item.id}
                    title={item.title}
                    summary={item.summary}
                    source={item.source}
                    sourceUrl={item.sourceUrl}
                    publishedAt={item.publishedAt}
                    imageUrl={item.imageUrl}
                    tags={item.tags}
                    index={index}
                    variant="compact"
                  />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      {sweepCategories.map((category) => (
        <div class="category-sweep-panel category-sweep-panel-single" data-category-panel={category.key} hidden>
          <div class="category-section">
            <div class="category-header">
              <span class="category-icon">{category.icon}</span>
              <h3 class="category-title">{category.label}</h3>
              <span class="category-count">{category.count}</span>
            </div>
            <div class="category-cards">
              {category.items.map((item, index) => (
                <ReportCard 
                  id={item.id}
                  title={item.title}
                  summary={item.summary}
                  source={item.source}
                  sourceUrl={item.sourceUrl}
                  publishedAt={item.publishedAt}
                  imageUrl={item.imageUrl}
                  tags={item.tags}
                  index={index}
                  variant="compact"
                />
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  const sweepRoot = document.querySelector('[data-category-sweep-root]');
  const sweepControls = Array.from(document.querySelectorAll('[data-category-filter]'));

  if (sweepRoot && sweepControls.length > 0) {
    const sweepPanels = Array.from(sweepRoot.querySelectorAll('[data-category-panel]'));

    const activatePanel = (key) => {
      sweepControls.forEach((control) => {
        const isActive = control.dataset.categoryFilter === key;
        control.classList.toggle('is-active', isActive);
        control.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      sweepPanels.forEach((panel) => {
        const isActive = panel.dataset.categoryPanel === key;
        panel.hidden = !isActive;
        panel.classList.toggle('is-active', isActive);
      });
    };

    sweepControls.forEach((control) => {
      control.addEventListener('click', () => activatePanel(control.dataset.categoryFilter || 'all'));
    });

    activatePanel('all');
  }
</script>

<style>
  .block {
    position: relative;
    z-index: var(--z-content);
    padding: var(--space-4xl) var(--space-xl);
  }

  .block-container {
    max-width: 1160px;
    margin: 0 auto;
  }

  .block-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .block-header-center {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  .header-eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-warm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .header-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .header-desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin: var(--space-xs) 0 0;
  }

  .block-categories {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .categories-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .category-sweep-controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .category-sweep-control {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-secondary);
    font: inherit;
    font-size: var(--text-sm);
    cursor: pointer;
    transition:
      border-color var(--duration-fast) ease,
      background-color var(--duration-fast) ease,
      color var(--duration-fast) ease,
      transform var(--duration-fast) ease;
  }

  .category-sweep-control:hover,
  .category-sweep-control.is-active {
    color: var(--text-primary);
    border-color: rgba(255, 159, 67, 0.24);
    background: rgba(255, 159, 67, 0.1);
    transform: translateY(-1px);
  }

  .category-sweep-control-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    min-height: 1.75rem;
    border-radius: 9999px;
    background: rgba(69, 163, 255, 0.12);
    color: var(--accent-cool);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .category-sweep-panels {
    position: relative;
  }

  .category-sweep-panel {
    animation: fadeInUp 240ms var(--ease-out);
  }

  .category-sweep-panel[hidden] {
    display: none;
  }

  .category-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border-subtle);
  }

  .category-icon {
    font-size: var(--text-base);
    opacity: 0.7;
  }

  .category-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .category-count {
    font-size: var(--text-xs);
    color: var(--text-muted);
    background: var(--bg-tertiary);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    margin-left: auto;
    font-weight: 500;
  }

  .category-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .category-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .block {
      padding: var(--space-3xl) var(--space-lg);
    }

    .category-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
