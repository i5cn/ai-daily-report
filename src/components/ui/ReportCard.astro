---
export interface Props {
  id: string;
  title: string;
  summary: string;
  source: string;
  sourceUrl: string;
  publishedAt: string;
  imageUrl?: string;
  tags?: string[];
  index?: number;
  // 社区贴文特有字段
  subreddit?: string;
  discussionUrl?: string;
  isCommunity?: boolean;
}

const { 
  title, 
  summary, 
  source, 
  sourceUrl, 
  publishedAt, 
  imageUrl,
  tags = [],
  index = 0,
  subreddit,
  discussionUrl,
  isCommunity = false
} = Astro.props;

// 格式化发布时间
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  
  if (diffHours < 1) {
    const diffMins = Math.floor(diffMs / (1000 * 60));
    return `${diffMins} 分钟前`;
  } else if (diffHours < 24) {
    return `${diffHours} 小时前`;
  } else {
    return date.toLocaleDateString('zh-CN', {
      month: 'short',
      day: 'numeric'
    });
  }
};

// 延迟动画（stagger effect）
const animationDelay = `${index * 60}ms`;

// 生成渐变色（用于无图占位）
const gradients = [
  'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
  'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
  'linear-gradient(135deg, #fa709a 0%, #fee140 100%)',
  'linear-gradient(135deg, #30cfd0 0%, #330867 100%)',
  'linear-gradient(135deg, #a8edea 0%, #fed6e3 100%)',
  'linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%)',
];
const gradientIndex = index % gradients.length;
const fallbackGradient = gradients[gradientIndex];

// 获取首字母用于占位显示
const getInitials = (text: string) => {
  return text.slice(0, 2).toUpperCase();
};

// 来源图标映射
const getSourceIcon = (sourceName: string) => {
  const iconMap: Record<string, string> = {
    'OpenAI Blog': '◆',
    'Google AI Blog': '◇',
    'TechCrunch AI': '◈',
    'Hugging Face Blog': '◉',
    'MIT News - AI': '✦',
    'Ars Technica - AI': '◊',
  };
  return iconMap[sourceName] || '◆';
};
---

<article 
  class={`report-card ${isCommunity ? 'community-card' : ''}`}
  style={`--delay: ${animationDelay}`}
  data-animate="fade-up"
>
  {/* 镜面高光边框 */}
  <div class="card-glow" aria-hidden="true"></div>
  
  {/* 图片区域 */}
  <div class="card-image-wrapper">
    {imageUrl ? (
      <img 
        src={imageUrl} 
        alt={title}
        class="card-image"
        loading="lazy"
      />
    ) : (
      <div class="card-image-placeholder" style={`background: ${fallbackGradient}`}>
        <span class="placeholder-initials">{getInitials(title)}</span>
      </div>
    )}
    <div class="card-image-overlay"></div>
    
    {/* 标签 */}
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 2).map(tag => (
          <span class={`tag ${isCommunity ? 'tag-community' : ''}`}>{tag}</span>
        ))}
      </div>
    )}
    
    {/* 社区标识 */}
    {isCommunity && subreddit && (
      <div class="community-badge">
        <span class="community-name">r/{subreddit}</span>
      </div>
    )}
  </div>
  
  {/* 内容区域 */}
  <div class="card-content">
    {/* 来源信息 */}
    <div class="card-meta">
      <div class="source-info">
        <span class="source-icon">{isCommunity ? '◉' : getSourceIcon(source)}</span>
        <span class="source-name">{isCommunity && subreddit ? `r/${subreddit}` : source}</span>
      </div>
      <time class="publish-time" datetime={publishedAt}>
        {formatDate(publishedAt)}
      </time>
    </div>
    
    {/* 标题 */}
    <h3 class="card-title">
      <a href={sourceUrl} target="_blank" rel="noopener noreferrer">
        {title}
      </a>
    </h3>
    
    {/* 摘要 */}
    <p class="card-summary">{summary}</p>
    
    {/* 操作栏 */}
    <div class="card-actions">
      <a 
        href={discussionUrl || sourceUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class={`view-btn ${isCommunity ? 'view-community' : ''}`}
      >
        <span class="btn-text">{isCommunity ? '查看讨论' : '阅读原文'}</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
  
  {/* 悬浮光泽扫过效果 */}
  <div class="card-sheen" aria-hidden="true"></div>
</article>

<style>
  .report-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--surface-elevated);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: 
      transform var(--duration-normal) var(--ease-metallic),
      box-shadow var(--duration-normal) var(--ease-metallic);
    animation: cardEnter 0.6s var(--ease-out) backwards;
    animation-delay: var(--delay);
    /* 多层阴影营造悬浮感 */
    box-shadow: 
      0 1px 2px rgba(0, 0, 0, 0.02),
      0 4px 8px rgba(0, 0, 0, 0.03),
      0 8px 16px rgba(0, 0, 0, 0.03),
      0 16px 32px rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.5);
  }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* 社区卡片特殊样式 */
  .community-card {
    border-color: rgba(234, 67, 53, 0.08);
  }

  /* 悬浮状态 - 浮在镜面上的效果 */
  .report-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 
      0 4px 8px rgba(0, 0, 0, 0.03),
      0 8px 24px rgba(0, 0, 0, 0.04),
      0 16px 48px rgba(0, 0, 0, 0.05),
      0 32px 64px rgba(0, 0, 0, 0.06),
      0 0 0 1px rgba(102, 157, 246, 0.1);
  }

  .community-card:hover {
    box-shadow: 
      0 4px 8px rgba(0, 0, 0, 0.03),
      0 8px 24px rgba(0, 0, 0, 0.04),
      0 16px 48px rgba(0, 0, 0, 0.05),
      0 32px 64px rgba(0, 0, 0, 0.06),
      0 0 0 1px rgba(234, 67, 53, 0.1);
  }

  /* 镜面高光边框 */
  .card-glow {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.9) 0%,
      rgba(102, 157, 246, 0.2) 30%,
      rgba(255, 255, 255, 0.6) 50%,
      rgba(102, 157, 246, 0.2) 70%,
      rgba(255, 255, 255, 0.9) 100%
    );
    background-size: 200% 200%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-normal) ease;
  }

  .community-card .card-glow {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.9) 0%,
      rgba(234, 67, 53, 0.15) 30%,
      rgba(255, 255, 255, 0.6) 50%,
      rgba(234, 67, 53, 0.15) 70%,
      rgba(255, 255, 255, 0.9) 100%
    );
    background-size: 200% 200%;
  }

  .report-card:hover .card-glow {
    opacity: 1;
    animation: glowFlow 3s linear infinite;
  }

  @keyframes glowFlow {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 200%; }
  }

  /* 图片区域 */
  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--lm-steel);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-metallic);
  }

  .report-card:hover .card-image {
    transform: scale(1.05);
  }

  /* 无图占位 */
  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .placeholder-initials {
    font-size: 2.5rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    letter-spacing: 0.15em;
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 50%,
      rgba(0, 0, 0, 0.3) 100%
    );
    pointer-events: none;
  }

  /* 标签 */
  .card-tags {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tag {
    padding: var(--space-xs) var(--space-sm);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--lm-chrome);
    font-weight: 500;
  }

  .tag-community {
    background: rgba(234, 67, 53, 0.85);
    border-color: rgba(234, 67, 53, 0.3);
  }

  /* 社区标识 */
  .community-badge {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: rgba(234, 67, 53, 0.9);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: white;
    font-weight: 600;
  }

  /* 内容区域 */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-xs);
  }

  .source-info {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--lm-iridescent);
    font-weight: 600;
  }

  .community-card .source-info {
    color: var(--accent-error);
  }

  .source-icon {
    font-size: 0.85em;
    opacity: 0.8;
  }

  .source-name {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .publish-time {
    color: var(--text-muted);
    font-weight: 500;
  }

  .card-title {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.5;
    margin: 0;
  }

  .card-title a {
    color: var(--text-primary);
    text-decoration: none;
    background: linear-gradient(
      to right,
      var(--lm-iridescent) 0%,
      var(--lm-iridescent) 50%,
      var(--text-primary) 50%
    );
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: background-position var(--duration-normal) ease;
  }

  .community-card .card-title a {
    background: linear-gradient(
      to right,
      var(--accent-error) 0%,
      var(--accent-error) 50%,
      var(--text-primary) 50%
    );
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-title a:hover {
    background-position: 0 0;
  }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 操作栏 */
  .card-actions {
    display: flex;
    align-items: center;
    margin-top: auto;
    padding-top: var(--space-md);
  }

  .view-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    background: rgba(102, 157, 246, 0.06);
    border: 1px solid rgba(102, 157, 246, 0.2);
    border-radius: var(--radius-md);
    color: var(--lm-iridescent);
    font-size: var(--text-xs);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-metallic);
  }

  .view-community {
    background: rgba(234, 67, 53, 0.06);
    border-color: rgba(234, 67, 53, 0.2);
    color: var(--accent-error);
  }

  .view-btn:hover {
    background: rgba(102, 157, 246, 0.12);
    border-color: var(--lm-iridescent);
    transform: translateY(-1px);
  }

  .view-community:hover {
    background: rgba(234, 67, 53, 0.1);
    border-color: var(--accent-error);
  }

  .view-btn svg {
    transition: transform var(--duration-fast) ease;
  }

  .view-btn:hover svg {
    transform: translate(2px, -2px);
  }

  /* 悬浮光泽扫过 */
  .card-sheen {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.4) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    pointer-events: none;
    transition: none;
  }

  .report-card:hover .card-sheen {
    animation: sheenSweep 0.8s ease forwards;
  }

  @keyframes sheenSweep {
    to {
      transform: translateX(100%);
    }
  }
</style>
