---
export interface Props {
  id: string;
  title: string;
  summary: string;
  source: string;
  sourceUrl: string;
  publishedAt: string;
  imageUrl?: string;
  tags?: string[];
  index?: number;
  // 社区贴文特有字段
  subreddit?: string;
  discussionUrl?: string;
  isCommunity?: boolean;
}

const { 
  title, 
  summary, 
  source, 
  sourceUrl, 
  publishedAt, 
  imageUrl,
  tags = [],
  index = 0,
  subreddit,
  discussionUrl,
  isCommunity = false
} = Astro.props;

// 格式化发布时间
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  
  if (diffHours < 1) {
    const diffMins = Math.floor(diffMs / (1000 * 60));
    return `${diffMins} 分钟前`;
  } else if (diffHours < 24) {
    return `${diffHours} 小时前`;
  } else {
    return date.toLocaleDateString('zh-CN', {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }
};

// 延迟动画（stagger effect）
const animationDelay = `${index * 100}ms`;

// 生成渐变色（用于无图占位）
const gradients = [
  'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
  'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
  'linear-gradient(135deg, #fa709a 0%, #fee140 100%)',
  'linear-gradient(135deg, #30cfd0 0%, #330867 100%)',
  'linear-gradient(135deg, #a8edea 0%, #fed6e3 100%)',
  'linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%)',
];
const gradientIndex = index % gradients.length;
const fallbackGradient = gradients[gradientIndex];

// 获取首字母用于占位显示
const getInitials = (text: string) => {
  return text.slice(0, 2).toUpperCase();
};

// 来源图标映射
const getSourceIcon = (sourceName: string) => {
  const iconMap: Record<string, string> = {
    'OpenAI Blog': '⚡',
    'Google AI Blog': '🔬',
    'TechCrunch AI': '💼',
    'Hugging Face Blog': '🤗',
    'MIT News - AI': '🎓',
    'Ars Technica - AI': '📰',
  };
  return iconMap[sourceName] || '◈';
};
---

<article 
  class={`report-card ${isCommunity ? 'community-card' : ''}`}
  style={`--delay: ${animationDelay}`}
  data-animate="fade-up"
>
  {/* 液态金属边框光效 */}
  <div class="card-border" aria-hidden="true"></div>
  
  {/* 图片区域 - 有图时显示图片，无图时显示渐变占位 */}
  <div class="card-image-wrapper">
    {imageUrl ? (
      <img 
        src={imageUrl} 
        alt={title}
        class="card-image"
        loading="lazy"
      />
    ) : (
      <div class="card-image-placeholder" style={`background: ${fallbackGradient}`}>
        <span class="placeholder-initials">{getInitials(title)}</span>
        <div class="placeholder-pattern"></div>
      </div>
    )}
    <div class="card-image-overlay"></div>
    
    {/* 标签 */}
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 2).map(tag => (
          <span class={`tag ${isCommunity ? 'tag-community' : ''}`}>{tag}</span>
        ))}
      </div>
    )}
    
    {/* 社区标识 */}
    {isCommunity && subreddit && (
      <div class="community-badge">
        <span class="community-icon">💬</span>
        <span class="community-name">r/{subreddit}</span>
      </div>
    )}
  </div>
  
  {/* 内容区域 */}
  <div class="card-content">
    {/* 来源信息 */}
    <div class="card-meta">
      <div class="source-info">
        <span class="source-icon">{isCommunity ? '💬' : getSourceIcon(source)}</span>
        <span class="source-name">{isCommunity && subreddit ? `r/${subreddit}` : source}</span>
      </div>
      <time class="publish-time" datetime={publishedAt}>
        {formatDate(publishedAt)}
      </time>
    </div>
    
    {/* 标题 */}
    <h3 class="card-title">
      <a href={sourceUrl} target="_blank" rel="noopener noreferrer">
        {title}
      </a>
    </h3>
    
    {/* 摘要 */}
    <p class="card-summary">{summary}</p>
    
    {/* 操作栏 */}
    <div class="card-actions">
      <a 
        href={discussionUrl || sourceUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class={`view-original-btn ${isCommunity ? 'view-discussion-btn' : ''}`}
      >
        <span class="btn-text">{isCommunity ? 'View Discussion' : 'View Original'}</span>
        <span class="btn-icon">
          <svg 
            width="16" 
            height="16" 
            viewBox="0 0 16 16" 
            fill="none" 
            xmlns="http://www.w3.org/2000/svg"
          >
            <path 
              d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" 
              stroke="currentColor" 
              stroke-width="1.5" 
              stroke-linecap="round" 
              stroke-linejoin="round"
            />
          </svg>
        </span>
        <span class="btn-shine" aria-hidden="true"></span>
      </a>
      
      <button class="share-btn" aria-label="分享">
        <svg 
          width="18" 
          height="18" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="2"
        >
          <circle cx="18" cy="5" r="3"/>
          <circle cx="6" cy="12" r="3"/>
          <circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
      </button>
    </div>
  </div>
  
  {/* 悬浮光泽效果 */}
  <div class="card-sheen" aria-hidden="true"></div>
</article>

<style>
  .report-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--surface-elevated);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: 
      transform var(--duration-normal) var(--ease-elastic),
      box-shadow var(--duration-normal) var(--ease-liquid);
    animation: fadeUp 0.6s var(--ease-out) backwards;
    animation-delay: var(--delay);
  }

  .community-card {
    border: 1px solid rgba(255, 107, 107, 0.1);
  }

  .community-card:hover {
    border-color: rgba(255, 107, 107, 0.2);
    box-shadow: 
      0 20px 40px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(255, 107, 107, 0.1),
      0 0 60px rgba(255, 107, 107, 0.08);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .report-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 
      0 20px 40px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.05),
      0 0 60px rgba(192, 192, 192, 0.1);
  }

  /* 液态金属边框 */
  .card-border {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.1) 0%,
      rgba(192, 192, 192, 0.3) 25%,
      rgba(255, 255, 255, 0.2) 50%,
      rgba(192, 192, 192, 0.3) 75%,
      rgba(255, 255, 255, 0.1) 100%
    );
    background-size: 200% 200%;
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    animation: borderFlow 4s linear infinite;
    opacity: 0;
    transition: opacity var(--duration-normal) ease;
  }

  .community-card .card-border {
    background: linear-gradient(
      135deg,
      rgba(255, 107, 107, 0.1) 0%,
      rgba(255, 142, 83, 0.2) 25%,
      rgba(255, 107, 107, 0.15) 50%,
      rgba(255, 142, 83, 0.2) 75%,
      rgba(255, 107, 107, 0.1) 100%
    );
    background-size: 200% 200%;
  }

  @keyframes borderFlow {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 200%; }
  }

  .report-card:hover .card-border {
    opacity: 1;
  }

  /* 图片区域 */
  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-liquid);
  }

  .report-card:hover .card-image {
    transform: scale(1.05);
  }

  /* 无图占位 */
  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .placeholder-initials {
    font-size: 3rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
    z-index: 1;
    letter-spacing: 0.1em;
  }

  .placeholder-pattern {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 40% 40%, rgba(0, 0, 0, 0.05) 0%, transparent 40%);
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(10, 10, 12, 0.3) 70%,
      rgba(10, 10, 12, 0.8) 100%
    );
  }

  /* 标签 */
  .card-tags {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tag {
    padding: var(--space-xs) var(--space-sm);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--lm-silver);
    font-weight: 500;
  }

  .tag-community {
    background: rgba(255, 107, 107, 0.2);
    border-color: rgba(255, 107, 107, 0.3);
    color: #ff8e8e;
  }

  /* 社区标识 */
  .community-badge {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    background: rgba(255, 107, 107, 0.9);
    backdrop-filter: blur(10px);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: white;
    font-weight: 600;
  }

  .community-icon {
    font-size: 0.9em;
  }

  /* 内容区域 */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-lg);
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-xs);
  }

  .source-info {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--lm-iridescent);
  }

  .community-card .source-info {
    color: #ff8e8e;
  }

  .source-icon {
    font-size: 0.8em;
    opacity: 0.8;
  }

  .source-name {
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .publish-time {
    color: var(--text-tertiary);
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
  }

  .card-title a {
    color: var(--text-primary);
    text-decoration: none;
    background: linear-gradient(
      to right,
      var(--lm-chrome) 0%,
      var(--lm-chrome) 50%,
      var(--text-primary) 50%
    );
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: background-position var(--duration-normal) ease;
  }

  .card-title a:hover {
    background-position: 0 0;
  }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 操作栏 */
  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: var(--space-md);
    border-top: 1px solid var(--border-subtle);
  }

  .view-original-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--surface-glass);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    overflow: hidden;
    transition: all var(--duration-fast) ease;
  }

  .view-discussion-btn {
    background: rgba(255, 107, 107, 0.1);
    border-color: rgba(255, 107, 107, 0.3);
    color: #ff8e8e;
  }

  .view-original-btn:hover {
    border-color: var(--lm-silver);
    box-shadow: 0 0 20px rgba(192, 192, 192, 0.15);
  }

  .view-discussion-btn:hover {
    border-color: #ff6b6b;
    box-shadow: 0 0 20px rgba(255, 107, 107, 0.2);
    background: rgba(255, 107, 107, 0.15);
  }

  .btn-text {
    position: relative;
    z-index: 1;
  }

  .btn-icon {
    position: relative;
    z-index: 1;
    display: flex;
    transition: transform var(--duration-fast) ease;
  }

  .view-original-btn:hover .btn-icon {
    transform: translate(2px, -2px);
  }

  .btn-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.2) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }

  .view-original-btn:hover .btn-shine {
    transform: translateX(100%);
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
  }

  .share-btn:hover {
    border-color: var(--lm-silver);
    color: var(--lm-silver);
    background: var(--surface-glass);
  }

  /* 悬浮光泽 */
  .card-sheen {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.03) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    pointer-events: none;
    transition: none;
  }

  .report-card:hover .card-sheen {
    animation: sheen 0.8s ease forwards;
  }

  @keyframes sheen {
    to {
      transform: translateX(100%);
    }
  }
</style>
