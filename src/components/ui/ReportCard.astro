---
export interface Props {
  id: string;
  title: string;
  summary: string;
  source: string;
  sourceUrl: string;
  publishedAt: string;
  imageUrl?: string;
  tags?: string[];
  index?: number;
  // 社区贴文特有字段
  subreddit?: string;
  discussionUrl?: string;
  isCommunity?: boolean;
  // 变体
  variant?: 'default' | 'compact' | 'minimal';
}

const { 
  title, 
  summary, 
  source, 
  sourceUrl, 
  publishedAt, 
  imageUrl,
  tags = [],
  index = 0,
  subreddit,
  discussionUrl,
  isCommunity = false,
  variant = 'default'
} = Astro.props;

// 格式化发布时间
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  
  if (diffHours < 1) {
    const diffMins = Math.floor(diffMs / (1000 * 60));
    return `${diffMins} 分钟前`;
  } else if (diffHours < 24) {
    return `${diffHours} 小时前`;
  } else {
    return date.toLocaleDateString('zh-CN', {
      month: 'short',
      day: 'numeric'
    });
  }
};

// 延迟动画（stagger effect）
const animationDelay = `${index * 50}ms`;

// 生成渐变色（用于无图占位）
const gradients = [
  'linear-gradient(135deg, #ea580c 0%, #fb923c 100%)',
  'linear-gradient(135deg, #0891b2 0%, #22d3ee 100%)',
  'linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%)',
  'linear-gradient(135deg, #059669 0%, #34d399 100%)',
  'linear-gradient(135deg, #dc2626 0%, #f87171 100%)',
  'linear-gradient(135deg, #2563eb 0%, #60a5fa 100%)',
];
const gradientIndex = index % gradients.length;
const fallbackGradient = gradients[gradientIndex];
const cardHref = discussionUrl || sourceUrl;
const hasSummary = Boolean(summary?.trim());
const displaySummary = hasSummary
  ? summary
  : isCommunity
    ? '打开社区讨论，快速浏览今日高热度观点。'
    : '打开原文，查看完整资讯与上下文。';

// 获取首字母用于占位显示
const getInitials = (text: string) => {
  return text.slice(0, 2).toUpperCase();
};

// 根据变体设置类名
const cardClasses = `report-card ${isCommunity ? 'community-card' : ''} report-card-${variant}`;
---

<article 
  class={cardClasses}
  style={`--delay: ${animationDelay}`}
>
  <a
    href={cardHref}
    target="_blank"
    rel="noopener noreferrer"
    class="report-card-link"
  >
    {variant !== 'minimal' && (
      <div class="card-image-wrapper">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={title}
            class="card-image"
            loading="lazy"
          />
        ) : (
          <div class="card-image-placeholder" style={`background: ${fallbackGradient}`}>
            <span class="placeholder-initials">{getInitials(title)}</span>
          </div>
        )}
        
        {/* 标签 */}
        {tags.length > 0 && variant === 'default' && (
          <div class="card-tags">
            {tags.slice(0, 2).map(tag => (
              <span class={`tag ${isCommunity ? 'tag-community' : ''}`}>{tag}</span>
            ))}
          </div>
        )}
        
        {/* 社区标识 */}
        {isCommunity && subreddit && variant === 'default' && (
          <div class="community-badge">
            <span>r/{subreddit}</span>
          </div>
        )}
      </div>
    )}
    
    {/* 内容区域 */}
    <div class="card-content">
      {/* 来源信息 */}
      <div class="card-meta">
        <div class="source-info">
          {isCommunity ? (
            <>
              <span class="source-icon-community">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 3.48 2.737 0 2.384-2.153 2.625-2.178 2.641l-.003.002c-.418.191-.706.159-1.122.241v.001c-.476.094-.798.137-1.179.137-.644 0-1.236-.093-1.754-.286-.647-.238-1.186-.59-1.592-1.035-.406-.445-.7-.978-.873-1.592a4.27 4.27 0 0 1-.077-1.887c.124-.511.355-.974.686-1.374.331-.4.753-.718 1.256-.949.503-.231 1.075-.347 1.703-.347.29 0 .574.02.848.061.273.04.544.104.81.188l.462-2.164h.002l.393-1.846c.032-.155.16-.27.319-.27h.002l2.53.533zm-5.077 5.827c-.521 0-.949.115-1.274.345-.325.23-.56.55-.695.956a2.49 2.49 0 0 0 .049 1.216c.125.41.349.752.668 1.019.319.267.72.401 1.195.401.277 0 .535-.04.772-.117.237-.078.46-.202.668-.37v-.001l.003-.002c.234-.19.408-.437.522-.737a2.22 2.22 0 0 0 .054-1.06 1.962 1.962 0 0 0-.597-.96 1.661 1.661 0 0 0-1.149-.425c-.166 0-.324.015-.472.044l-.016.003a1.94 1.94 0 0 0-.332.076l-.007.002h-.002c-.029.008-.057.018-.084.029l-.008.003zm8.58 1.17a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75zm-10.01 0a.875.875 0 1 0 0 1.75.875.875 0 0 0 0-1.75z"/>
                </svg>
              </span>
              <span class="source-name">r/{subreddit}</span>
            </>
          ) : (
            <>
              <span class="source-icon"></span>
              <span class="source-name">{source}</span>
            </>
          )}
        </div>
        <time class="publish-time" datetime={publishedAt}>
          {formatDate(publishedAt)}
        </time>
      </div>
      
      {/* 标题 */}
      <h3 class="card-title">{title}</h3>
      
      {/* 摘要 - 仅在 default 和 compact 变体中显示 */}
      {variant !== 'minimal' && (
        <p class="card-summary">{displaySummary}</p>
      )}
      
      {/* 操作栏 */}
      <div class="card-actions">
        <span class={`card-cta ${isCommunity ? 'card-cta-community' : ''}`}>
          <span>{isCommunity ? '查看讨论' : '阅读原文'}</span>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M6 3H3v10h10V10M7 9l6-6m0 0v4m0-4H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>

<style>
  /* ===== BASE CARD STYLES - v4 refined ===== */
  .report-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: 
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) var(--ease-out);
    animation: cardEnter 0.5s var(--ease-out) backwards;
    animation-delay: var(--delay);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-subtle);
  }

  .report-card-link {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .report-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--border-default);
  }

  /* ===== VARIANT: COMPACT - v4 refined ===== */
  .report-card-compact {
    border-radius: var(--radius-md);
  }

  .report-card-compact .card-image-wrapper {
    aspect-ratio: 16 / 9;
  }

  .report-card-compact .card-content {
    padding: var(--space-md);
    gap: var(--space-xs);
  }

  .report-card-compact .card-title {
    font-size: 0.8125rem;
    line-height: 1.45;
    font-weight: 500;
  }

  .report-card-compact .card-summary {
    font-size: 0.75rem;
    line-height: 1.5;
    -webkit-line-clamp: 2;
  }
  
  @media (max-width: 768px) {
    .report-card-compact .card-title {
      font-size: 0.75rem;
    }
    
    .report-card-compact .card-summary {
      font-size: 0.6875rem;
      -webkit-line-clamp: 1;
    }
    
    .report-card-compact .card-content {
      padding: var(--space-sm);
    }
  }

  .report-card-compact .card-actions {
    padding-top: var(--space-sm);
  }

  .report-card-compact .action-link {
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
  }

  /* ===== VARIANT: MINIMAL ===== */
  .report-card-minimal {
    background: transparent;
    border: none;
    box-shadow: none;
    border-radius: 0;
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: var(--space-md);
  }

  .report-card-minimal:hover {
    transform: none;
    box-shadow: none;
    border-color: var(--border-default);
  }

  .report-card-minimal .card-content {
    padding: 0;
    gap: var(--space-xs);
  }

  .report-card-minimal .card-title {
    font-size: var(--text-base);
  }

  .report-card-minimal .card-actions {
    padding-top: var(--space-sm);
  }

  /* ===== IMAGE AREA - v4 refined ===== */
  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-tertiary);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .report-card:hover .card-image {
    transform: scale(1.04);
  }

  /* 无图占位 - 更精致 */
  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  
  .card-image-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.1) 0%, transparent 40%);
    opacity: 0.6;
  }

  .placeholder-initials {
    font-size: 1.5rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    letter-spacing: 0.1em;
    position: relative;
    z-index: 1;
  }
  
  @media (max-width: 768px) {
    .placeholder-initials {
      font-size: 1.125rem;
    }
  }

  /* 标签 - 更精致 */
  .card-tags {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tag {
    padding: var(--space-xs) var(--space-sm);
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(12px);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--text-inverse);
    font-weight: 500;
  }

  .tag-community {
    background: rgba(251, 146, 60, 0.85);
  }

  /* 社区标识 - 更精致 */
  .community-badge {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: rgba(251, 146, 60, 0.85);
    backdrop-filter: blur(12px);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: white;
    font-weight: 500;
  }

  /* ===== CONTENT AREA - v4 refined ===== */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-xs);
    margin-bottom: var(--space-xs);
  }

  .source-info {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .source-icon {
    width: 5px;
    height: 5px;
    background: var(--accent-cool);
    border-radius: 50%;
  }

  .source-icon-community {
    display: flex;
    align-items: center;
    color: var(--accent-warm);
  }

  .source-icon-community svg {
    width: 12px;
    height: 12px;
  }

  .source-name {
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.01em;
  }

  .community-card .source-name {
    color: var(--accent-warm);
  }

  .publish-time {
    color: var(--text-muted);
    font-weight: 500;
  }

  .card-title {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.45;
    margin: 0;
  }

  .card-title {
    color: var(--text-primary);
    background: linear-gradient(
      to right,
      var(--accent-cool) 0%,
      var(--accent-cool) 50%,
      var(--text-primary) 50%
    );
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: background-position var(--duration-normal) ease;
  }

  .community-card .card-title {
    background: linear-gradient(
      to right,
      var(--accent-warm) 0%,
      var(--accent-warm) 50%,
      var(--text-primary) 50%
    );
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .report-card-link:hover .card-title,
  .report-card-link:focus-visible .card-title {
    background-position: 0 0;
  }

  .card-title a {
    color: var(--text-primary);
    text-decoration: none;
    background: linear-gradient(
      to right,
      var(--accent-cool) 0%,
      var(--accent-cool) 50%,
      var(--text-primary) 50%
    );
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: background-position var(--duration-normal) ease;
  }

  .community-card .card-title a {
    background: linear-gradient(
      to right,
      var(--accent-warm) 0%,
      var(--accent-warm) 50%,
      var(--text-primary) 50%
    );
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-title a:hover {
    background-position: 0 0;
  }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ===== ACTIONS ===== */
  .card-actions {
    display: flex;
    align-items: center;
    margin-top: auto;
    padding-top: var(--space-md);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    background: var(--accent-cool-soft);
    border: 1px solid rgba(56, 189, 248, 0.12);
    border-radius: var(--radius-sm);
    color: var(--accent-cool);
    font-size: var(--text-xs);
    font-weight: 500;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .card-cta-community {
    background: var(--accent-warm-soft);
    border-color: rgba(251, 158, 75, 0.12);
    color: var(--accent-warm);
  }

  .report-card-link:hover .card-cta,
  .report-card-link:focus-visible .card-cta {
    background: rgba(56, 189, 248, 0.12);
    border-color: rgba(56, 189, 248, 0.2);
  }

  .report-card-link:hover .card-cta-community,
  .report-card-link:focus-visible .card-cta-community {
    background: rgba(251, 158, 75, 0.12);
    border-color: rgba(251, 158, 75, 0.2);
  }

  .card-cta svg {
    transition: transform var(--duration-fast) ease;
  }

  .report-card-link:hover .card-cta svg,
  .report-card-link:focus-visible .card-cta svg {
    transform: translate(2px, -2px);
  }
</style>
